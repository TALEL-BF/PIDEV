<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.media.MediaView?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.CollectionController"
            prefWidth="1000" prefHeight="600"
            style="-fx-background-color: linear-gradient(to bottom right, #f8f0ff, #e9e0ff);">

    <!-- Haut de page avec titre -->
    <top>
        <VBox alignment="CENTER" spacing="10" style="-fx-padding: 20;">
            <Label text="🎁 MA COLLECTION MAGIQUE 🎁"
                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #8b5cf6;"/>
            <Label text="Les animaux et accessoires que tu as gagnés !"
                   style="-fx-font-size: 16px; -fx-text-fill: #6d28d9;"/>

            <!-- SECTION VIDÉO AJOUTÉE ICI -->
            <VBox fx:id="videoSection" spacing="10" alignment="CENTER" style="-fx-padding: 10;">
                <Label text="🎬 Ma vidéo test" style="-fx-font-size: 18px; -fx-text-fill: #5b21b6;"/>
                <MediaView fx:id="videoMediaView" fitWidth="400" fitHeight="250"/>
            </VBox>

            <!-- Onglets pour filtrer -->
            <HBox alignment="CENTER" spacing="20" style="-fx-padding: 20 0 10 0;">
                <Button fx:id="btnTout" text="Tout"
                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 25;"/>
                <Button fx:id="btnAnimaux" text="Animaux"
                        style="-fx-background-color: #c4b5fd; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 25;"/>
                <Button fx:id="btnAccessoires" text="Accessoires"
                        style="-fx-background-color: #c4b5fd; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 25;"/>
            </HBox>

            <!-- BOUTON API -->
            <HBox alignment="CENTER" spacing="20" style="-fx-padding: 0 0 20 0;">
                <Button fx:id="btnTesterAPI" text="🎲 Gagner avec l'API"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 25; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <!-- Centre avec la grille de collection -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="20" style="-fx-padding: 20;">

                <!-- SECTION ANIMAUX -->
                <VBox fx:id="animauxSection" spacing="10">
                    <Label text="🦁 Mes animaux"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #5b21b6;"/>
                    <FlowPane fx:id="animauxFlowPane" hgap="20" vgap="20" alignment="CENTER"/>
                </VBox>

                <!-- SECTION ACCESSOIRES -->
                <VBox fx:id="accessoiresSection" spacing="10">
                    <Label text="👑 Mes accessoires"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #5b21b6;"/>
                    <FlowPane fx:id="accessoiresFlowPane" hgap="20" vgap="20" alignment="CENTER"/>
                </VBox>

                <!-- Message si collection vide -->
                <VBox fx:id="emptyMessage" alignment="CENTER" spacing="20" visible="false" managed="false">
                    <Label text="🎈 Ta collection est vide pour le moment !"
                           style="-fx-font-size: 20px; -fx-text-fill: #6b7280;"/>
                    <Label text="Participe à des événements pour gagner des animaux et accessoires !"
                           style="-fx-font-size: 14px; -fx-text-fill: #9ca3af;"/>
                    <Button text="Voir les événements"
                            style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 10 30; -fx-cursor: hand;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- Bouton retour -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-padding: 20;">
            <Button text="← Retour"
                    style="-fx-background-color: #f0f0f0; -fx-text-fill: #6d28d9; -fx-background-radius: 30; -fx-padding: 8 25; -fx-font-weight: bold; -fx-cursor: hand;"
                    onAction="#handleRetour"/>
        </HBox>
    </bottom>

</BorderPane>