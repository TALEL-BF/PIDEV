<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.PlanteController"
            prefWidth="400" prefHeight="600"
            style="-fx-background-color: #2d5a27;">

    <top>
        <VBox alignment="CENTER" spacing="10" style="-fx-padding: 20;">
            <Label text="🌱 MA PLANTE 🌱"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #ffd700;"/>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20">
            <!-- Image de la plante -->
            <ImageView fx:id="planteImageView" fitWidth="150" fitHeight="150"/>

            <!-- Statistiques -->
            <GridPane hgap="20" vgap="10" alignment="CENTER">
                <Label text="Jour" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Label fx:id="jourLabel" text="5" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="💧 Eau:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Label fx:id="eauLabel" text="15/30" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="☀️ Soleil:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <Label fx:id="soleilLabel" text="23/30" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="🌿 Engrais:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <Label fx:id="engraisLabel" text="8/30" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
            </GridPane>
        </VBox>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="15" style="-fx-padding: 30;">
            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="btnArroser" text="💧 Arroser"
                        style="-fx-background-color: #4a90e2; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;"/>
                <Button fx:id="btnSoleil" text="☀️ Soleil"
                        style="-fx-background-color: #f9a825; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;"/>
            </HBox>
            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="btnEngrais" text="🌿 Engrais"
                        style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;"/>
                <Button fx:id="btnHarvest" text="🍅 Récolter"
                        style="-fx-background-color: #c2185b; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;"/>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>