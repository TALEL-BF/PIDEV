<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.FaceEmotionControllerV2"
            prefWidth="1508" prefHeight="848"
            style="-fx-background-color: 	#add8e6;">  <!-- ← Light blue background -->

    <!-- ========== SIDEBAR ========== -->
    <left>
        <!-- Sidebar sans effet de lumière -->
        <VBox prefWidth="240.0"
              minWidth="240.0"
              maxWidth="240.0"
              spacing="15"
              style="-fx-background-color: linear-gradient(to bottom, #7B2FF7, #5F0FFF); -fx-padding: 20 15;">

            <!-- Logo + Titre -->
            <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 5 0 10 0;">
                <ImageView fitWidth="65" fitHeight="65" preserveRatio="true">
                    <image>
                        <Image url="@assets/logo.png"/>
                    </image>
                </ImageView>
                <VBox>
                    <Label text="AutiCare" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 900;"/>
                    <Label text="✨ Plateforme éducative ✨" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 12px; -fx-font-style: italic;"/>
                </VBox>
            </HBox>

            <!-- Connecté en tant qu'étudiant -->
            <VBox spacing="4" style="-fx-padding: 5 0 5 0;">
                <Label text="Connecté en tant que" style="-fx-text-fill: #F0E6FF; -fx-font-size: 13px; -fx-font-weight: 600;"/>
                <Label text="👤 Élève Magicien"
                       style="-fx-background-color: rgba(255,255,255,0.2);
                          -fx-text-fill: white;
                          -fx-padding: 8 15;
                          -fx-background-radius: 30;
                          -fx-font-weight: bold;
                          -fx-font-size: 15px;
                          -fx-border-color: white;
                          -fx-border-width: 1;
                          -fx-border-radius: 30;"/>
            </VBox>

            <Separator style="-fx-background-color: rgba(255,255,255,0.2); -fx-padding: 5 0;"/>

            <!-- Menu -->
            <VBox spacing="8" style="-fx-padding: 5 0;">
                <Button text="📚 Nos cours"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-background-radius: 12;
                           -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand;"/>

                <Button text="🗓️ Emploi du temps"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-background-radius: 12;
                           -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand;"/>

                <Button text="🩺 Nos consultations"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-background-radius: 12;
                           -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand; -fx-wrap-text: true;"/>

                <!-- Événements en surbrillance (légèrement plus visible) -->
                <Button text="🎉 Nos événements"
                        style="-fx-background-color: rgba(255,255,255,0.3); -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-background-radius: 12;
                           -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;"/>

                <Button text="🎮 Nos jeux éducatifs"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-background-radius: 12;
                           -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand;"/>
            </VBox>

            <VBox VBox.vgrow="ALWAYS" />

            <!-- Déconnexion - plus petite et sans effet -->
            <Button text="Déconnexion"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 8 15; -fx-background-radius: 12;
                       -fx-font-size: 13px; -fx-font-weight: 600; -fx-cursor: hand;"/>

            <!-- Message inspirant -->
            <Label text="💫Un espace pensé pour chaque autiste💫"
                   wrapText="true"
                   style="-fx-text-fill: #E0D7FF; -fx-font-size: 12px; -fx-font-style: italic;
                      -fx-padding: 10 0 5 0;
                      -fx-alignment: CENTER;"/>
        </VBox>
    </left>


    <!-- ========== MAIN CONTENT ========== -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="15" alignment="TOP_CENTER"
                  style="-fx-padding: 10 30; -fx-background-color: #E6F0FF;">

                <!-- ===== LIGNE TITRE + RETOUR (même niveau) ===== -->
                <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 5 0;">
                    <Button fx:id="backButton"
                            text="← Retour"
                            style="-fx-background-color: #f8f9fa; -fx-text-fill: #7B2FF7;
                                   -fx-background-radius: 30; -fx-padding: 6 18;
                                   -fx-cursor: hand; -fx-border-color: #d0c4ff;
                                   -fx-border-radius: 30; -fx-border-width: 1; -fx-font-size: 14px;"/>

                    <!-- Pousseur pour centrer le titre -->
                    <Region HBox.hgrow="ALWAYS"/>

                    <Label fx:id="titreLabel" text=""
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #7B2FF7;"/>

                    <!-- Pousseur pour équilibrer (invisible mais maintient le centrage) -->
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- ===== PROGRESSION (avant le titre) ===== -->
                <VBox spacing="8" style="-fx-max-width: 900;">
                    <HBox alignment="CENTER">
                        <Label text="📊 Progression" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #7B2FF7;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="scoreLabel" text="0/3"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #28A745; -fx-background-color: #F0F8FF; -fx-padding: 3 12; -fx-background-radius: 20;"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER">

                        <ProgressBar fx:id="progressBar" prefWidth="500" progress="0.33" style="-fx-accent: #7B2FF7; -fx-pref-height: 12;"/>
                        <Label fx:id="pourcentageLabel" text="33%" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #7B2FF7;"/>
                    </HBox>
                </VBox>

                <!-- ===== GRAND CADRE PRINCIPAL ===== -->
                <VBox spacing="15" alignment="CENTER"
                      style="-fx-background-color: white;
                             -fx-background-radius: 30;
                             -fx-border-color: #7B2FF7;
                             -fx-border-width: 3;
                             -fx-border-radius: 30;
                             -fx-effect: dropshadow(gaussian, rgba(123,47,247,0.2), 20, 0, 0, 8);
                             -fx-max-width: 950;
                             -fx-padding: 20;">

                    <!-- LIGNE CAMÉRA + HISTOIRE -->
                    <HBox spacing="20" alignment="CENTER">

                        <!-- CAMÉRA AVEC LABEL FLOTTANT -->
                        <StackPane fx:id="cameraContainer"
                                   style="-fx-background-color: #2d2d2d; -fx-background-radius: 20; -fx-padding: 3;">

                            <ImageView fx:id="cameraView" fitWidth="380" fitHeight="280" preserveRatio="true"/>

                            <!-- Label flottant pour l'émotion en direct -->
                            <Label fx:id="liveEmotionLabel"
                                   text=""
                                   style="-fx-background-color: rgba(123,47,247,0.9);
                                          -fx-text-fill: white;
                                          -fx-font-size: 18px;
                                          -fx-font-weight: bold;
                                          -fx-padding: 8 20;
                                          -fx-background-radius: 40;
                                          -fx-border-color: white;
                                          -fx-border-width: 2;
                                          -fx-border-radius: 40;
                                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 3);"
                                   StackPane.alignment="BOTTOM_CENTER">
                                <StackPane.margin>
                                    <Insets bottom="15"/>
                                </StackPane.margin>
                            </Label>
                        </StackPane>

                        <!-- HISTOIRE -->
                        <VBox fx:id="histoireContainer" spacing="8"
                              style="-fx-background-color: #F5F0FF; -fx-background-radius: 20; -fx-padding: 15;
                                     -fx-border-color: #E5D9FF; -fx-border-width: 2; -fx-border-radius: 20;
                                     -fx-pref-width: 380; -fx-pref-height: 280; -fx-min-height: 280; -fx-max-height: 280;">

                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label text="📖" style="-fx-font-size: 20px;"/>
                                <Label fx:id="histoireTitreLabel" text="Histoire"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #7B2FF7;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="histoireEtapeLabel" text="1"
                                       style="-fx-background-color: #7B2FF7; -fx-text-fill: white; -fx-padding: 3 10;
                                              -fx-background-radius: 15; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                            </HBox>

                            <Label fx:id="histoirePhraseLabel" wrapText="true" VBox.vgrow="ALWAYS"
                                   style="-fx-font-size: 16px; -fx-padding: 12; -fx-background-color: white;
                                          -fx-background-radius: 12; -fx-border-color: #E5D9FF; -fx-border-radius: 12;
                                          -fx-font-style: italic; -fx-text-fill: #374151;"/>
                        </VBox>
                    </HBox>


                    <!-- LES 4 ÉMOTIONS AVEC ÉMOJIS COLORÉS FONCÉS -->
                    <HBox spacing="25" alignment="CENTER" style="-fx-padding: 5 0;">

                        <!-- JOIE avec emoji jaune FONCÉ -->
                        <VBox alignment="CENTER" spacing="2">
                            <Label text="😊"
                                   style="-fx-font-size: 30px;
                      -fx-text-fill: #B45309;  /* Jaune foncé / ocre */
                      -fx-background-color: white;
                      -fx-background-radius: 25;
                      -fx-padding: 8;
                      -fx-border-color: #FBBF24;
                      -fx-border-width: 2;
                      -fx-border-radius: 25;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 3, 0, 1, 1);"/>
                            <Label text="Joie" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #B45309;"/>
                        </VBox>

                        <!-- TRISTESSE avec emoji bleu FONCÉ -->
                        <VBox alignment="CENTER" spacing="2">
                            <Label text="😢"
                                   style="-fx-font-size: 30px;
                      -fx-text-fill: #1E40AF;  /* Bleu foncé */
                      -fx-background-color: white;
                      -fx-background-radius: 25;
                      -fx-padding: 8;
                      -fx-border-color: #3b82f6;
                      -fx-border-width: 2;
                      -fx-border-radius: 25;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 3, 0, 1, 1);"/>
                            <Label text="Tristesse" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E40AF;"/>
                        </VBox>

                        <!-- COLÈRE avec emoji rouge FONCÉ -->
                        <VBox alignment="CENTER" spacing="2">
                            <Label text="😠"
                                   style="-fx-font-size: 30px;
                      -fx-text-fill: #B91C1C;  /* Rouge foncé */
                      -fx-background-color: white;
                      -fx-background-radius: 25;
                      -fx-padding: 8;
                      -fx-border-color: #ef4444;
                      -fx-border-width: 2;
                      -fx-border-radius: 25;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 3, 0, 1, 1);"/>
                            <Label text="Colère" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #B91C1C;"/>
                        </VBox>

                        <!-- SURPRISE avec emoji violet FONCÉ -->
                        <VBox alignment="CENTER" spacing="2">
                            <Label text="😲"
                                   style="-fx-font-size: 30px;
                      -fx-text-fill: #6B21A8;  /* Violet foncé */
                      -fx-background-color: white;
                      -fx-background-radius: 25;
                      -fx-padding: 8;
                      -fx-border-color: #a855f7;
                      -fx-border-width: 2;
                      -fx-border-radius: 25;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 3, 0, 1, 1);"/>
                            <Label text="Surprise" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #6B21A8;"/>
                        </VBox>
                    </HBox>

                    <!-- BOUTONS CONTRÔLE -->
                    <HBox spacing="15" alignment="CENTER" style="-fx-padding: 5 0;">
                        <Button fx:id="startButton" text="▶ Démarrer"
                                style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 13px;
                                       -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 7 18;
                                       -fx-cursor: hand;"/>
                        <Button fx:id="stopButton" text="⏹ Arrêter"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 13px;
                                       -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 7 18;
                                       -fx-cursor: hand;"/>
                        <Button fx:id="captureButton" text="📸 CAPTURER"
                                style="-fx-background-color: #7B2FF7; -fx-text-fill: white; -fx-font-size: 13px;
                                       -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 7 22;
                                       -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(123,47,247,0.3), 5, 0, 0, 2);"/>
                    </HBox>

                    <!-- CARTE EXPLICATION ÉMOTION -->
                    <VBox fx:id="explicationContainer" spacing="8" visible="false" managed="false"
                          style="-fx-background-color: #F5F0FF; -fx-background-radius: 20; -fx-padding: 15;
                                 -fx-border-color: #E5D9FF; -fx-border-width: 2; -fx-border-radius: 20;
                                 -fx-max-width: 700;">

                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label fx:id="emotionIconeLabel" text="😊" style="-fx-font-size: 28px;"/>
                            <Label fx:id="emotionNomLabel" text="La joie"
                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #7B2FF7;"/>
                        </HBox>

                        <Label fx:id="emotionDescriptionLabel" wrapText="true"
                               style="-fx-font-size: 15px; -fx-text-fill: #374151; -fx-padding: 5 0;"/>
                    </VBox>

                    <!-- ÉMOTION DÉTECTÉE -->
                    <VBox spacing="3" alignment="CENTER"
                          style="-fx-background-color: #F5F0FF; -fx-background-radius: 20; -fx-padding: 10; -fx-max-width: 400;">
                        <Label text="🎭 Émotion détectée" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #7B2FF7;"/>
                        <Label fx:id="emotionLabel" text="En attente..."
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #7B2FF7;"/>
                    </VBox>

                    <!-- STATUT -->
                    <Label fx:id="statusLabel" text="Prêt" style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
                </VBox>

                <!-- BOUTONS NAVIGATION -->
                <HBox spacing="25" alignment="CENTER" style="-fx-padding: 5 0 15 0;">
                    <Button fx:id="autresHistoiresBtn" text="🔄 Autres histoires"
                            style="-fx-background-color: #10b981; -fx-text-fill: white;
                   -fx-background-radius: 25; -fx-padding: 7 22; -fx-font-size: 14px;
                   -fx-font-weight: bold; -fx-cursor: hand;"/>
                    <Button fx:id="precedentBtn" text="← Précédent"
                            style="-fx-background-color: #f8f9fa; -fx-border-color: #7B2FF7; -fx-text-fill: #7B2FF7;
                                   -fx-border-radius: 25; -fx-padding: 7 22; -fx-font-size: 14px;
                                   -fx-font-weight: bold; -fx-cursor: hand; -fx-border-width: 2;"/>

                    <Button fx:id="suivantBtn" text="Suivant →"
                            style="-fx-background-color: #7B2FF7; -fx-text-fill: white;
                                   -fx-background-radius: 25; -fx-padding: 7 22; -fx-font-size: 14px;
                                   -fx-font-weight: bold; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(123,47,247,0.3), 5, 0, 0, 2);"/>

                </HBox>

                <!-- Petit espace en bas -->
                <Region prefHeight="5"/>
            </VBox>

        </ScrollPane>
    </center>
</BorderPane>