<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.EventPlanningController"
            prefWidth="1000" prefHeight="700"
            style="-fx-background-color: linear-gradient(to bottom right, #f0e9ff, #e0d7ff);">

    <!-- ========== TOP BAR ========== -->
    <top>
        <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: white; -fx-background-radius: 0 0 30 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Button fx:id="backButton" text="← Retour"
                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 8 20; -fx-cursor: hand;"/>
                <Label fx:id="eventTitleLabel" text="Planning de l'événement"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #5b21b6;"/>
            </HBox>
            <ProgressBar fx:id="loadingBar" visible="false" prefWidth="400" style="-fx-accent: #8b5cf6;"/>
        </VBox>
    </top>

    <!-- ========== CENTER ========== -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="25" style="-fx-padding: 25;">

                <!-- ===== BOUTON GÉNÉRER LE PLANNING ===== -->
                <HBox alignment="CENTER">
                    <Button fx:id="generateBtn" text="Générer le planning avec IA"
                            style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 40; -fx-padding: 15 40; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.4), 15, 0, 0, 5);"/>
                </HBox>

                <!-- ===== INFOS DE L'ÉVÉNEMENT ===== -->
                <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 30; -fx-padding: 20; -fx-border-color: #c4b5fd; -fx-border-width: 2; -fx-border-radius: 30;">
                    <Label text="📋 Détails de l'événement" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #6d28d9;"/>
                    <GridPane hgap="20" vgap="10">
                        <Label text="📅 Date :" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="dateLabel" text="..." GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="⏰ Heure :" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="timeLabel" text="..." GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="📍 Lieu :" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="locationLabel" text="..." GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="👥 Participants :" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="participantsLabel" text="..." GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="🏷️ Type :" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                        <Label fx:id="typeLabel" text="..." GridPane.rowIndex="4" GridPane.columnIndex="1" style="-fx-text-fill: #8b5cf6;"/>
                    </GridPane>
                </VBox>

                <!-- ===== PLANNING GÉNÉRÉ ===== -->
                <VBox fx:id="planningContainer" spacing="15" visible="false" managed="false"
                      style="-fx-background-color: white; -fx-background-radius: 30; -fx-padding: 20; -fx-border-color: #c4b5fd; -fx-border-width: 2; -fx-border-radius: 30;">

                    <Label text="📅 Planning détaillé" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #6d28d9;"/>

                    <!-- Horaire détaillé MODIFIABLE -->
                    <VBox spacing="10" style="-fx-background-color: #f5f0ff; -fx-background-radius: 20; -fx-padding: 15;">
                        <Label text="⏰ HORAIRE (modifiable)" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #5b21b6;"/>

                        <VBox fx:id="scheduleContainer" spacing="8">
                            <!-- Les lignes seront ajoutées dynamiquement -->
                        </VBox>

                        <!-- Boutons pour ajouter/supprimer des lignes - MODIFIÉ -->
                        <HBox spacing="10" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                            <!-- BOUTON AJOUTER EN VIOLET -->
                            <Button fx:id="addRowBtn" text="➕ Ajouter une ligne"
                                    style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 5 15; -fx-cursor: hand;"/>

                            <!-- BOUTON SUPPRIMER EN GRIS -->
                            <Button fx:id="removeRowBtn" text="🗑️ Supprimer la dernière"
                                    style="-fx-background-color: #9CA3AF; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 5 15; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>

                    <!-- Conseils personnalisés -->
                    <VBox spacing="10" style="-fx-background-color: #f5f0ff; -fx-background-radius: 20; -fx-padding: 15;">
                        <Label text="💡 CONSEILS" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #5b21b6;"/>
                        <Label fx:id="conseilLabel" wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #4b5563;"/>
                    </VBox>

                    <!-- À préparer -->
                    <VBox spacing="10" style="-fx-background-color: #f5f0ff; -fx-background-radius: 20; -fx-padding: 15;">
                        <Label text="🎒 À PRÉPARER" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #5b21b6;"/>
                        <Label fx:id="preparationLabel" wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #4b5563;"/>
                    </VBox>

                    <!-- Boutons d'action -->
                    <HBox spacing="10" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                        <Button fx:id="savePlanningBtn" text="💾 Sauvegarder le planning"
                                style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 10 30; -fx-cursor: hand;"/>
                        <Button fx:id="deletePlanningBtn" text="🗑️ Supprimer le planning"
                                style="-fx-background-color: #9CA3AF; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 10 30; -fx-cursor: hand;"
                                visible="false" managed="false"/>
                    </HBox>
                </VBox>

                <!-- Message si pas encore généré -->
                <VBox fx:id="emptyStateContainer" alignment="CENTER" spacing="15"
                      style="-fx-background-color: white; -fx-background-radius: 30; -fx-padding: 50; -fx-border-color: #c4b5fd; -fx-border-width: 2; -fx-border-radius: 30;">
                    <Label text="📅" style="-fx-font-size: 64px;"/>
                    <Label text="Aucun planning généré pour le moment" style="-fx-font-size: 18px; -fx-text-fill: #6b7280; -fx-font-style: italic;"/>
                    <Label text="Clique sur le bouton ci-dessus pour créer ton planning personnalisé !" style="-fx-font-size: 14px; -fx-text-fill: #9ca3af;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>