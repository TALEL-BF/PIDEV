<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.effect.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="Controller.EventDetailsController"
           stylesheets="@styles/app.css"
           prefWidth="1508" prefHeight="848">

    <!-- ========== CONTENU PRINCIPAL (BORDERPANE) ========== -->
    <BorderPane style="-fx-background-color: linear-gradient(to bottom right, #f8f0ff, #e9e0ff);">

        <!-- ========== SIDEBAR AVEC EFFET DE VERRE ========== -->
        <left>
            <!-- Sidebar sans effet de lumière -->
            <VBox prefWidth="240.0"
                  minWidth="240.0"
                  maxWidth="240.0"
                  spacing="15"
                  style="-fx-background-color: linear-gradient(to bottom, #7B2FF7, #5F0FFF); -fx-padding: 20 15;">

                <!-- Logo + Titre -->
                <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 5 0 10 0;">
                    <ImageView fitWidth="50" fitHeight="50" preserveRatio="true">
                        <image>
                            <Image url="@assets/logo.png"/>
                        </image>
                    </ImageView>
                    <VBox>
                        <Label text="AutiCare" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 900;"/>
                        <Label text="✨ Plateforme éducative ✨" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 12px; -fx-font-style: italic;"/>
                    </VBox>
                </HBox>

                <!-- Connecté en tant qu'étudiant -->
                <VBox spacing="4" style="-fx-padding: 5 0 5 0;">
                    <Label text="Connecté en tant que" style="-fx-text-fill: #F0E6FF; -fx-font-size: 13px; -fx-font-weight: 600;"/>
                    <Label text="👤 Élève Magicien"
                           style="-fx-background-color: rgba(255,255,255,0.2);
                          -fx-text-fill: white;
                          -fx-padding: 8 15;
                          -fx-background-radius: 30;
                          -fx-font-weight: bold;
                          -fx-font-size: 15px;
                          -fx-border-color: white;
                          -fx-border-width: 1;
                          -fx-border-radius: 30;"/>
                </VBox>

                <Separator style="-fx-background-color: rgba(255,255,255,0.2); -fx-padding: 5 0;"/>

                <!-- Menu -->
                <VBox spacing="8" style="-fx-padding: 5 0;">
                    <Button text="📚 Nos cours"
                            style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-background-radius: 12;
                           -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand;"/>

                    <Button text="🗓️ Emploi du temps"
                            style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-background-radius: 12;
                           -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand;"/>

                    <Button text="🩺 Nos consultations"
                            style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-background-radius: 12;
                           -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand; -fx-wrap-text: true;"/>

                    <!-- Événements en surbrillance (légèrement plus visible) -->
                    <Button text="🎉 Nos événements"
                            style="-fx-background-color: rgba(255,255,255,0.3); -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-background-radius: 12;
                           -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;"/>

                    <Button text="🎮 Nos jeux éducatifs"
                            style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-background-radius: 12;
                           -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand;"/>
                </VBox>

                <VBox VBox.vgrow="ALWAYS" />

                <!-- Déconnexion - plus petite et sans effet -->
                <Button text="Déconnexion"
                        style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 8 15; -fx-background-radius: 12;
                       -fx-font-size: 13px; -fx-font-weight: 600; -fx-cursor: hand;"/>

                <!-- Message inspirant -->
                <Label text="💫Un espace pensé pour chaque autiste💫"
                       wrapText="true"
                       style="-fx-text-fill: #E0D7FF; -fx-font-size: 12px; -fx-font-style: italic;
                      -fx-padding: 10 0 5 0;
                      -fx-alignment: CENTER;"/>
            </VBox>
        </left>

        <!-- ========== MAIN CONTENT AVEC ÉLÉMENTS FLOTTANTS ========== -->
        <center>
            <ScrollPane fitToWidth="true" fitToHeight="true"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <VBox spacing="25" style="-fx-padding: 25;">

                    <!-- HERO BANNER AVEC EFFET DE LUMIÈRE -->

                    <!-- BOUTON RETOUR STYLISÉ -->
                    <HBox alignment="CENTER_LEFT">
                        <Button fx:id="backButton"
                                text="← Retour à la liste "
                                onAction="#goBackToShowEvent"
                                style="-fx-background-color: #f0f0f0;
                                       -fx-text-fill: #6d28d9;
                                       -fx-background-radius: 40;
                                       -fx-padding: 8 25;
                                       -fx-font-size: 14px;
                                       -fx-font-weight: bold;
                                       -fx-cursor: hand;
                                       -fx-border-color: #c4b5fd;
                                       -fx-border-radius: 40;
                                       -fx-border-width: 2;
                                       -fx-effect: dropshadow(gaussian, rgba(196,181,253,0.3), 5, 0, 0, 2);"/>
                    </HBox>


                    <!-- TITRE À GAUCHE + TRÉSOR À DROITE (même ligne) -->
                    <!-- TITRE À GAUCHE + IMAGE CLIQUABLE À DROITE (même ligne) -->
                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 0 5;">

                        <!-- Titre à gauche -->
                        <Label fx:id="eventTitleLabel" text="Titre de l'Événement"
                               style="-fx-font-size: 42px; -fx-font-weight: 900; -fx-text-fill: #5b21b6;
                  -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.3), 5, 0, 2, 2);"/>

                        <!-- Pousseur pour envoyer l'image à droite -->
                        <Region HBox.hgrow="ALWAYS"/>

                        
                        <ImageView fx:id="topRightIcon"
                                   fitWidth="90"
                                   fitHeight="90"
                                   preserveRatio="true"
                                   style="-fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.4), 10, 0, 0, 3);"
                                   >
                            <image>
                                <Image url="@assets/lista.png"/>  <!-- Remplace par ton image -->
                            </image>
                        </ImageView>
                    </HBox>
                    <!-- CARTE PRINCIPALE MAGIQUE -->
                    <VBox spacing="30"
                          style="-fx-background-color: linear-gradient(to bottom, rgba(255,255,255,0.95), rgba(249,245,255,0.95));
                                 -fx-background-radius: 40;
                                 -fx-padding: 35;
                                 -fx-border-color: #c4b5fd;
                                 -fx-border-width: 3;
                                 -fx-border-radius: 40;
                                 -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.2), 20, 0, 0, 10);">

                        <!-- CONTENU PRINCIPAL -->
                        <HBox spacing="30">

                            <!-- COLONNE GAUCHE -->
                            <VBox spacing="20" style="-fx-pref-width: 600;">

                                <!-- IMAGE DE L'ÉVÉNEMENT AVEC CADRE MAGIQUE -->
                                <StackPane style="-fx-background-color: transparent; -fx-padding: 0;">
                                    <ImageView fx:id="eventImageView" fitWidth="580" fitHeight="300" preserveRatio="true"
                                               style="-fx-background-radius: 40; -fx-border-radius: 40;
                                                      -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.4), 15, 0, 0, 5);">
                                        <image><Image url="@assets/event-default.jpg"/></image>
                                    </ImageView>
                                    <Rectangle width="580" height="300"
                                               fill="transparent"
                                               stroke="#c4b5fd"
                                               strokeWidth="3"
                                               arcWidth="40" arcHeight="40"
                                               style="-fx-effect: dropshadow(gaussian, white, 10, 0, 0, 0);"/>
                                </StackPane>

                                <!-- DESCRIPTION ENCADRÉE -->
                                <VBox spacing="8"
                                      style="-fx-background-color: #f5f0ff;
                                             -fx-background-radius: 30;
                                             -fx-padding: 20;
                                             -fx-border-color: #d9c9ff;
                                             -fx-border-width: 2;
                                             -fx-border-radius: 30;">

                                    <Label text="📖 Description de l'événement"
                                           style="-fx-font-size: 22px;
                                                  -fx-font-weight: bold;
                                                  -fx-text-fill: #6d28d9;"/>

                                    <TextArea fx:id="descriptionArea"
                                              wrapText="true"
                                              editable="false"
                                              prefRowCount="5"
                                              style="-fx-font-size: 16px;
                                                     -fx-text-fill: #4a5568;
                                                     -fx-control-inner-background: transparent;
                                                     -fx-background-color: transparent;
                                                     -fx-border-color: transparent;"/>
                                </VBox>
                            </VBox>

                            <!-- COLONNE DROITE AVEC INFOS MAGIQUES -->
                            <VBox spacing="20" style="-fx-pref-width: 400;">

                                <!-- CARTE INFOS MAGIQUES AVEC IMAGES -->
                                <VBox spacing="15"
                                      style="-fx-background-color: linear-gradient(to bottom, #f5f0ff, #ffffff);
                 -fx-background-radius: 30;
                 -fx-padding: 25;
                 -fx-border-color: #c4b5fd;
                 -fx-border-width: 2;
                 -fx-border-radius: 30;">

                                    <Label text="✨ Informations magiques ✨"
                                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;"/>

                                    <GridPane hgap="15" vgap="15">
                                        <!-- DATE avec image -->
                                        <ImageView fitWidth="49" fitHeight="49" preserveRatio="true"
                                                   GridPane.rowIndex="0" GridPane.columnIndex="0">
                                            <image>
                                                <Image url="@assets/calender.png"/>  <!-- Image calendrier numéro 2 -->
                                            </image>
                                        </ImageView>
                                        <VBox GridPane.rowIndex="0" GridPane.columnIndex="1">
                                            <Label text="Date magique" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
                                            <Label fx:id="dateLabel" text="15 Mars 2026" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #000000;"/>
                                        </VBox>

                                        <!-- HEURE avec image -->
                                        <ImageView fitWidth="49" fitHeight="49" preserveRatio="true"
                                                   GridPane.rowIndex="1" GridPane.columnIndex="0">
                                            <image>
                                                <Image url="@assets/timeee.png"/>  <!-- Image horloge numéro 2 -->
                                            </image>
                                        </ImageView>
                                        <VBox GridPane.rowIndex="1" GridPane.columnIndex="1">
                                            <Label text="Heure enchantée" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
                                            <Label fx:id="timeLabel" text="14:30 - 16:30" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #000000;"/>
                                        </VBox>

                                        <!-- LIEU avec image -->
                                        <ImageView fitWidth="49" fitHeight="49" preserveRatio="true"
                                                   GridPane.rowIndex="2" GridPane.columnIndex="0">
                                            <image>
                                                <Image url="@assets/lieu1.png"/>  <!-- Image lieu numéro 2 -->
                                            </image>
                                        </ImageView>
                                        <VBox GridPane.rowIndex="2" GridPane.columnIndex="1">
                                            <Label text="Lieu secret" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
                                            <Label fx:id="locationLabel" text="Forêt Enchantée" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #000000;"/>
                                        </VBox>

                                        <!-- TYPE avec image -->
                                        <ImageView fitWidth="49" fitHeight="49" preserveRatio="true"
                                                   GridPane.rowIndex="3" GridPane.columnIndex="0">
                                            <image>
                                                <Image url="@assets/tag2.png"/>  <!-- Image étiquette numéro 2 -->
                                            </image>
                                        </ImageView>
                                        <VBox GridPane.rowIndex="3" GridPane.columnIndex="1">
                                            <Label text="Type d'aventure" style="-fx-font-size: 11px; -fx-text-fill: #000000;"/>
                                            <Label fx:id="typeLabel" text="Atelier Magique" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #8b5cf6;"/>
                                        </VBox>
                                    </GridPane>

                                    <Button text="👤 Voir planning utilisateur"
                                            onAction="#openUserPlanning"
                                            style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 15;"/>
                                </VBox>

                                <!-- LIEN VERS LE PLANNING -->


                                <!-- À propos avec bulle -->
                                <VBox spacing="10"
                                      style="-fx-background-color: #faf5ff;
                                             -fx-background-radius: 30;
                                             -fx-padding: 20;
                                             -fx-border-color: #c4b5fd;
                                             -fx-border-width: 2;
                                             -fx-border-radius: 30;"
                                      VBox.vgrow="ALWAYS">
                                    <Label text="👤 Qui organise ?" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;"/>
                                    <Label fx:id="aboutLabel" wrapText="true"
                                           text="L'association AutiCare crée des aventures magiques adaptées à tous les enfants. Notre équipe de fées et de lutins est formée pour accueillir chaque enfant dans un monde de douceur et de bienveillance."
                                           style="-fx-text-fill: #4b5563; -fx-font-size: 15px; -fx-line-spacing: 5;" VBox.vgrow="ALWAYS"/>
                                </VBox>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- SECTION ANALYSE COMPACTE -->
                    <HBox spacing="20" alignment="CENTER" style="-fx-padding: 20 0 10 0;">

                        <!-- Niveau sonore -->
                        <HBox spacing="5" alignment="CENTER">
                            <Label fx:id="noiseEmojiLabel" text="🔇" style="-fx-font-size: 20px;"/>
                            <Label fx:id="noiseLabel" text="Calme" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4b5563;"/>
                        </HBox>

                        <Label text="•" style="-fx-font-size: 18px; -fx-text-fill: #c4b5fd;"/>

                        <!-- Stimulation sensorielle -->
                        <HBox spacing="5" alignment="CENTER">
                            <Label fx:id="sensoryEmojiLabel" text="🧘" style="-fx-font-size: 20px;"/>
                            <Label fx:id="sensoryLabel" text="Faible" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4b5563;"/>
                        </HBox>

                        <Label text="•" style="-fx-font-size: 18px; -fx-text-fill: #c4b5fd;"/>

                        <!-- Âge recommandé -->
                        <HBox spacing="5" alignment="CENTER">
                            <Label fx:id="ageEmojiLabel" text="👥" style="-fx-font-size: 20px;"/>
                            <Label fx:id="ageLabel" text="5-10 ans" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4b5563;"/>
                        </HBox>

                        <Label text="•" style="-fx-font-size: 18px; -fx-text-fill: #c4b5fd;"/>

                        <!-- Niveau d'activité -->
                        <HBox spacing="5" alignment="CENTER">
                            <Label fx:id="activityEmojiLabel" text="🪑" style="-fx-font-size: 20px;"/>
                            <Label fx:id="activityLabel" text="Assis" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4b5563;"/>
                        </HBox>

                        <Label text="•" style="-fx-font-size: 18px; -fx-text-fill: #c4b5fd;"/>

                        <!-- Recommandation -->
                        <HBox spacing="5" alignment="CENTER">
                            <Label fx:id="recommendationIcon" text="⭐⭐⭐" style="-fx-font-size: 16px; -fx-text-fill: #fbbf24;"/>
                            <Label fx:id="recommendationLabel" text="Excellent" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4b5563;"/>
                        </HBox>

                        <Label text="•" style="-fx-font-size: 18px; -fx-text-fill: #c4b5fd;"/>

                        <!-- Bouton analyser -->
                        <Button fx:id="analyzeBtn" text="🔍 analyser"
                                style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold;
                                       -fx-background-radius: 30; -fx-padding: 5 20; -fx-cursor: hand;
                                       -fx-font-size: 13px; -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.3), 8, 0, 0, 3);"/>
                    </HBox>

                    <!-- BOUTONS D'ACTION MAGIQUES -->
                    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10 0 20 0;">
                        <Button fx:id="registerBtn" text="✨ Participer à l'aventure ✨"
                                style="-fx-background-color: linear-gradient(to right, #8b5cf6, #c084fc);
                                       -fx-text-fill: white;
                                       -fx-font-size: 18px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 50;
                                       -fx-padding: 15 50;
                                       -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.5), 15, 0, 0, 5);"/>

                        <Button fx:id="rapportIABtn" text="💡🧩Conseils IA"
                                style="-fx-background-color: #c4b5fd;
                                       -fx-text-fill: white;
                                       -fx-font-size: 16px;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 50;
                                       -fx-padding: 12 30;
                                       -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(196,181,253,0.5), 10, 0, 0, 3);"/>
                        <Button fx:id="viewParticipantsBtn" text="👥 Voir les participants"
                                style="-fx-background-color: #10b981;
                   -fx-text-fill: white;
                   -fx-font-size: 16px;
                   -fx-font-weight: bold;
                   -fx-background-radius: 50;
                   -fx-padding: 12 30;
                   -fx-cursor: hand;
                   -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.5), 10, 0, 0, 3);"/>
                    </HBox>



                    <!-- SECTION MÉTÉO - Style Informations -->
                    <VBox spacing="15" alignment="CENTER"
                          style="-fx-background-color: linear-gradient(to bottom, #f5f0ff, #ffffff);
                 -fx-background-radius: 30;
                 -fx-padding: 25;
                 -fx-border-color: #c4b5fd;
                 -fx-border-width: 2;
                 -fx-border-radius: 30;
                 -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.1), 10, 0, 0, 5);">

                        <!-- Titre Météo du jour -->
                        <Label text="☀️ MÉTÉO DU JOUR ☀️"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;
                      -fx-padding: 0 0 10 0;"/>

                        <!-- Ville - SANS CADRE -->
                        <HBox alignment="CENTER" spacing="8">
                            <Label text="📍" style="-fx-font-size: 20px;"/>
                            <Label fx:id="weatherCityLabel" text="Bizerte"
                                   style="-fx-font-size: 18px; -fx-font-weight: 600; -fx-text-fill: #5b21b6;"/>
                        </HBox>

                        <!-- ESPACEMENT ENTRE LES ÉLÉMENTS MÉTÉO -->
                        <HBox spacing="40" alignment="CENTER" style="-fx-padding: 15 0 10 0;">

                            <!-- Température -->
                            <VBox spacing="5" alignment="CENTER">
                                <ImageView fitWidth="50" fitHeight="50" preserveRatio="true">
                                    <image>
                                        <Image url="@assets/soleil.png"/>
                                    </image>
                                </ImageView>
                                <Label fx:id="weatherTempValue" text="22°C"
                                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                                <Label text="Température" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                            </VBox>

                            <!-- Humidité -->
                            <VBox spacing="5" alignment="CENTER">
                                <ImageView fitWidth="50" fitHeight="50" preserveRatio="true">
                                    <image>
                                        <Image url="@assets/goutte.png"/>
                                    </image>
                                </ImageView>
                                <Label fx:id="weatherHumidityValue" text="65%"
                                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
                                <Label text="Humidité" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                            </VBox>

                            <!-- Vent -->
                            <VBox spacing="5" alignment="CENTER">
                                <ImageView fitWidth="50" fitHeight="50" preserveRatio="true">
                                    <image>
                                        <Image url="@assets/vent2.png"/>
                                    </image>
                                </ImageView>
                                <Label fx:id="weatherWindValue" text="10 km/h"
                                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #059669;"/>
                                <Label text="Vent" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                            </VBox>
                        </HBox>

                        <!-- Petit message météo (optionnel) -->
                        <Label text="🌤️ Belle journée pour sortir !"
                               style="-fx-font-size: 14px; -fx-font-style: italic; -fx-text-fill: #8b5cf6;
                      -fx-background-color: #f5f0ff; -fx-padding: 5 15; -fx-background-radius: 30;"/>
                    </VBox>

                    <!-- SECTION SPONSORS MAGIQUE -->
                    <VBox spacing="15" alignment="CENTER"
                          style="-fx-background-color: linear-gradient(to bottom, #f5f0ff, #ffffff);
                                 -fx-background-radius: 40;
                                 -fx-padding: 30;
                                 -fx-border-color: #d9c9ff;
                                 -fx-border-width: 2;
                                 -fx-border-radius: 40;">

                        <Label text="✨ Nos partenaires ✨"
                               style="-fx-font-size: 24px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #8b5cf6;"/>

                        <FlowPane fx:id="sponsorsFlowPane"
                                  hgap="25"
                                  vgap="15"
                                  alignment="CENTER"/>
                    </VBox>








                        <!-- Contenu par-dessus (centré) -->
                        <VBox alignment="CENTER" spacing="10">








                        </VBox>
                        <!-- BOUTON POUR LA V2 (version texte) -->
    <!-- <Button text="🎭 Détection V2"
            onAction="#openFaceEmotionV2"
            style="-fx-background-color: #7B2FF7; -fx-text-fill: white;
-fx-font-weight: bold; -fx-background-radius: 30;
-fx-padding: 8 20; -fx-cursor: hand; -fx-font-size: 14px;
-fx-effect: dropshadow(gaussian, rgba(123,47,247,0.3), 5, 0, 0, 2);"/>-->





</VBox>

</ScrollPane>

</center>
</BorderPane>

<!-- ========== BOUTON FLOTTANT (TOUJOURS VISIBLE) ========== -->
    <ImageView fx:id="floatingEmotionBtn"
               fitWidth="300"
               fitHeight="80"
               preserveRatio="true"
               style="-fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.5), 15, 0, 0, 5);"
               StackPane.alignment="BOTTOM_RIGHT"
               onMouseClicked="#openFaceEmotionV2">
        <image>
            <Image url="@assets/bam2.png"/>  <!-- Ton image -->
        </image>
    </ImageView>

</StackPane>