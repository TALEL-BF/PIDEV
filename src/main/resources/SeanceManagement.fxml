<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="Controller.SeanceManagementController"
      spacing="14">

    <!-- Title -->
    <VBox spacing="3">
        <Label text="Gestion des Séances 📚" styleClass="page-title"/>
        <Label text="Gérez les séances et les informations associées" styleClass="page-subtitle"/>
    </VBox>

    <!-- Search + Filters + Add Button -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Rechercher une séance..." styleClass="search"/>
        <HBox styleClass="filters" spacing="8">
            <ToggleButton fx:id="filterTous" text="Tous" selected="true"/>
            <ToggleButton fx:id="filterPlanifiee" text="Planifiée"/>
            <ToggleButton fx:id="filterConfirme" text="Confirmé"/>
            <ToggleButton fx:id="filterTermine" text="Terminé"/>
            <ToggleButton fx:id="filterAnnule" text="Annulé"/>
        </HBox>

        <Region HBox.hgrow="ALWAYS"/>

        <Button text="➕ Nouvelle Séance" onAction="#addNewSeance"
                style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 10 20; -fx-font-weight: 700; -fx-font-size: 14;"/>
    </HBox>

    <Label fx:id="countLabel" text="0 Séances" styleClass="count"/>

    <!-- Table View -->
    <TableView fx:id="seanceTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
        <columns>
            <TableColumn fx:id="colTitre" text="Titre"/>
            <TableColumn fx:id="colDate" text="Date"/>
            <TableColumn fx:id="colJours" text="Jour"/>
             <TableColumn fx:id="colDuree" text="Durée"/>
            <TableColumn fx:id="colStatut" text="Statut"/>
            <TableColumn fx:id="colActions" text="Actions"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

</VBox>

