<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f5f5f7;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.MeetingController">
    <children>
        <!-- Top Bar -->
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="20.0" style="-fx-background-color: #ffffff; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="Live Session">
                   <HBox.margin>
                      <javafx.geometry.Insets left="20.0" />
                   </HBox.margin>
                </Label>
                <StackPane HBox.hgrow="ALWAYS" />
                <Button fx:id="copyLinkBtn" mnemonicParsing="false" onAction="#handleCopyLink" style="-fx-background-color: #E6E6FA; -fx-text-fill: #6A0DAD; -fx-background-radius: 20; -fx-font-weight: bold; -fx-cursor: hand;" text="Copy Link">
                   <HBox.margin>
                      <javafx.geometry.Insets />
                   </HBox.margin>
                   <padding>
                      <javafx.geometry.Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                   </padding>
                </Button>
                <Button fx:id="closeBtn" mnemonicParsing="false" onAction="#handleClose" style="-fx-background-color: #ffcccc; -fx-text-fill: #cc0000; -fx-background-radius: 20; -fx-font-weight: bold; -fx-cursor: hand;" text="Close">
                   <padding>
                      <javafx.geometry.Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                   </padding>
                   <HBox.margin>
                      <javafx.geometry.Insets right="20.0" />
                   </HBox.margin>
                </Button>
            </children>
        </HBox>

        <!-- Main Content Area -->
        <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="60.0">
            <children>
                <!-- Start Screen -->
                <VBox fx:id="startScreen" alignment="CENTER" spacing="20.0" style="-fx-background-color: #f5f5f7;">
                    <children>
                        <Label style="-fx-font-size: 24px; -fx-text-fill: #444444;" text="Start a Live Meeting" />
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #777777;" text="The meeting will open in a secure application window" />
                        <Button fx:id="startMeetingBtn" mnemonicParsing="false" onAction="#handleStartMeeting" style="-fx-background-color: #6A0DAD; -fx-text-fill: white; -fx-font-size: 18px; -fx-background-radius: 30; -fx-font-weight: bold; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(106, 13, 173, 0.3), 10, 0, 0, 5);" text="Start Meeting">
                            <padding>
                                <javafx.geometry.Insets bottom="15.0" left="40.0" right="40.0" top="15.0" />
                            </padding>
                        </Button>
                    </children>
                </VBox>

                <!-- Meeting View -->
                <StackPane fx:id="meetingContainer" visible="false">
                    <children>
                        <WebView fx:id="show" minHeight="-1.0" minWidth="-1.0" prefHeight="-1.0" prefWidth="-1.0" />
                        <ProgressIndicator fx:id="loadingIndicator" maxHeight="50.0" maxWidth="50.0" style="-fx-progress-color: #6A0DAD;" />
                    </children>
                </StackPane>
            </children>
        </StackPane>
    </children>
</AnchorPane>

