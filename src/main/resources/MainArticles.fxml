<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<?import javafx.scene.shape.Circle?>
<BorderPane fx:id="root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auticare.Controller.MainArticlesController"
            stylesheets="@styles/app.css"
            styleClass="appRoot">

    <left>
        <VBox prefWidth="260"
              minWidth="260"
              maxWidth="260"
              spacing="10"
              style="-fx-background-color: linear-gradient(to bottom, #7c3aed, #64009D);
                 -fx-background-radius: 25;
                 -fx-padding: 25 15;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 5);">

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 0 15 5;">
                <ImageView fitHeight="40.0" fitWidth="40.0" preserveRatio="true">
                    <Image url="@assets/logo.png" />
                </ImageView>
                <VBox spacing="2">
                    <Label text="AutiCare" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <Label text="Psychologue" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 11px;"/>
                </VBox>
            </HBox>

            <Separator style="-fx-background-color: rgba(255,255,255,0.2); -fx-pref-height: 1;"/>

            <!-- Profil utilisateur (à remplir par le contrôleur) -->
            <VBox alignment="CENTER" spacing="10"
                  style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 15; -fx-padding: 15;">
                <Circle radius="30" fill="white" />
                <VBox alignment="CENTER" spacing="2">
                    <Label fx:id="userNameLabel" text="Parent"
                           style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label fx:id="userEmailLabel" text="parent@test.com"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;"/>
                    <Label text="👪 Parent"
                           style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 11px; -fx-background-color: rgba(255,255,255,0.2); -fx-padding: 3 8; -fx-background-radius: 10;"/>
                </VBox>
            </VBox>

            <!-- ===== MENU ===== -->
            <VBox spacing="8" style="-fx-padding: 10 0 20 0;">

                <!-- 🏠 Accueil -->
                <Button text="🏠 Accueil"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-cursor: hand; -fx-padding: 12 15; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-background-radius: 10;"
                        maxWidth="Infinity"
                        onAction="#showDashboard"/>

                <!-- 👤 Mon Profil -->
                <Button text="👤 Mon Profil"
                        onAction="#goToProfile"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-cursor: hand; -fx-padding: 12 15; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-background-radius: 10;"
                        maxWidth="Infinity"/>

                <!-- 📅 Emploi du temps -->
                <Button text="📅 Emploi du temps"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-cursor: hand; -fx-padding: 12 15; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-background-radius: 10;"
                        maxWidth="Infinity"
                        onAction="#showSchedule"/>

                <!-- 📚 Cours -->
                <Button text="📚 Cours"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-cursor: hand; -fx-padding: 12 15; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-background-radius: 10;"
                        maxWidth="Infinity"
                        onAction="#showCourses"/>

                <!-- 📚 Articles & Conseils (page active) -->
                <Button text="📚 Articles &amp; Conseils"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 12 15; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-background-radius: 10;"
                        maxWidth="Infinity"
                        onAction="#showArticles"/>


                <!-- 📊 Suivi thérapeutique -->
                <Button text="📊 Suivi thérapeutique"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-cursor: hand; -fx-padding: 12 15; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-background-radius: 10;"
                        maxWidth="Infinity"
                        onAction="#showTherapeuticFollowUp"/>


                <!-- 🎉 Événements -->
                <Button text="🎉 Événements"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-cursor: hand; -fx-padding: 12 15; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-background-radius: 10;"
                        maxWidth="Infinity"
                        onAction="#showEvents"/>

                <!-- 🎮 Jeux -->
                <Button text="🎮 Jeux"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-cursor: hand; -fx-padding: 12 15; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-background-radius: 10;"
                        maxWidth="Infinity"
                        onAction="#showGames"/>


            </VBox>

            <VBox VBox.vgrow="ALWAYS" />

            <!-- Déconnexion -->
            <Button text="🚪 Déconnexion"
                    style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 10; -fx-padding: 12 15; -fx-font-size: 14px; -fx-alignment: CENTER_LEFT;"
                    maxWidth="Infinity"
                    onAction="#handleLogout"/>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="pageScroll">
            <VBox spacing="18" styleClass="page" prefWidth="980">
                <padding>
                    <Insets top="20" right="26" bottom="26" left="26"/>
                </padding>

                <HBox spacing="16" styleClass="heroCard" alignment="CENTER_LEFT">
                    <StackPane minWidth="90" minHeight="90"
                               prefWidth="90" prefHeight="90"
                               styleClass="heroImageWrapper">

                        <ImageView fitWidth="90"
                                   fitHeight="90"
                                   preserveRatio="true">
                            <image>
                                <Image url="@assets/PSY.png"/>
                            </image>
                        </ImageView>

                    </StackPane>


                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Conseils de psychologues 🧩" styleClass="heroTitle"/>
                        <Label text="Des articles pour les enfants en général et pour les enfants autistes : routines, communication, gestion des émotions, sommeil, etc."
                               wrapText="true" styleClass="heroSub"/>
                        <Label text="✦ Nouveaux articles chaque semaine" styleClass="pillInfo"/>
                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <Label text="📰 Articles &amp; Conseils" styleClass="sectionTitle"/>
                    <Label text="Recherchez un thème et ouvrez un article en un clic 🤍" styleClass="sectionSub"/>
                </VBox>

                <HBox spacing="12" alignment="CENTER_LEFT" styleClass="searchRow">
                    <TextField fx:id="searchField"
                               promptText="Rechercher un article..."
                               styleClass="searchField"
                               HBox.hgrow="ALWAYS"/>


                    <Button text="Rechercher" styleClass="searchBtn" fx:id="btnSearch"/>
                </HBox>

                <HBox spacing="10" styleClass="chipsRow">
                    <ToggleButton text="Général" styleClass="chip" fx:id="chipGeneral"/>
                    <ToggleButton text="Autisme" styleClass="chip" fx:id="chipAutisme"/>
                    <ToggleButton text="Sommeil" styleClass="chip" fx:id="chipSommeil"/>
                    <ToggleButton text="Comportement" styleClass="chip" fx:id="chipComportement"/>
                </HBox>


                <Label fx:id="countLabel" text="0 Articles disponibles" styleClass="countLabel"/>

                <TilePane fx:id="cardsPane"
                          hgap="50"
                          vgap="50"
                          prefTileWidth="320"
                          alignment="TOP_CENTER"
                          styleClass="cardsPane">
                    <padding>
                        <Insets top="10" right="40" bottom="10" left="40"/>
                    </padding>
                </TilePane>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
