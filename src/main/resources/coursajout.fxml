<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.Glow?>

<AnchorPane prefWidth="1300.0" prefHeight="800.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.CoursAjout"
            style="-fx-background-color: #F0F2F5;">

    <children>
        <HBox AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">

            <!-- ================= SIDEBAR (INCHANGÉE) ================= -->
            <VBox prefWidth="220.0"
                  minWidth="220.0"
                  maxWidth="220.0"
                  spacing="15"
                  style="-fx-background-color: linear-gradient(to bottom, #7B2FF7, #5F0FFF); -fx-padding:20;">

                <HBox alignment="CENTER_LEFT" spacing="5">
                    <VBox alignment="CENTER">
                        <ImageView fitHeight="32.0" fitWidth="32.0" preserveRatio="true">
                            <image>
                                <Image url="@images/logo.png"/>
                            </image>
                        </ImageView>
                    </VBox>
                    <Label text="AutiCare"
                           style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;">
                        <font>
                            <Font size="20.0"/>
                        </font>
                    </Label>
                </HBox>

                <Separator/>

                <Button text="Gestion des utilisateurs"
                        style="-fx-background-color: transparent; -fx-text-fill:white; -fx-cursor: hand;"/>

                <Button text="Gestion des cours"
                        style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill:white; -fx-background-radius:10; -fx-cursor: hand;"/>

                <Button text="Gestion des emplois"
                        style="-fx-background-color: transparent; -fx-text-fill:white; -fx-cursor: hand;"/>

                <Button text="Gestion des événements"
                        style="-fx-background-color: transparent; -fx-text-fill:white; -fx-cursor: hand;"/>

                <Button text="Gestion des suivie consultation"
                        style="-fx-background-color: transparent; -fx-text-fill:white; -fx-cursor: hand;"/>

                <Button text="Gestion des jeux"
                        style="-fx-background-color: transparent; -fx-text-fill:white; -fx-cursor: hand;"/>

                <VBox VBox.vgrow="ALWAYS" />

                <Button text="Déconnexion"
                        style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill:white; -fx-cursor: hand; -fx-background-radius:10;"/>

            </VBox>

            <!-- ================= CONTENU PRINCIPAL AMÉLIORÉ ================= -->
            <ScrollPane fitToWidth="true"
                        HBox.hgrow="ALWAYS"
                        style="-fx-background: #F0F2F5; -fx-border-width: 0;">
                <content>
                    <VBox spacing="25" style="-fx-background-color: #F0F2F5; -fx-padding: 30;">

                        <!-- Titre avec icône et effet -->
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <StackPane style="-fx-background-color: linear-gradient(to bottom right, #7B2FF7, #9F5FF7);
                                             -fx-background-radius: 15;
                                             -fx-padding: 12;
                                             -fx-effect: dropshadow(gaussian, rgba(123,47,247,0.4), 10, 0, 0, 3);">
                                <Label text="📚" style="-fx-font-size: 28px; -fx-text-fill: white;"/>
                            </StackPane>
                            <Label text="Gestion des Cours"
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;">
                                <effect>
                                    <DropShadow color="#CCCCCC" radius="2" spread="0.1"/>
                                </effect>
                            </Label>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="✨ Nouveau cours"
                                   style="-fx-background-color: #F0E6FF; -fx-text-fill: #7B2FF7; -fx-padding: 8 15; -fx-background-radius: 20; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        </HBox>

                        <!-- ================= CARTE AJOUT COURS AMÉLIORÉE ================= -->
                        <VBox spacing="20"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 25;
                                     -fx-border-radius: 25;
                                     -fx-border-color: #7B2FF7;
                                     -fx-border-width: 2;
                                     -fx-padding: 30;
                                     -fx-effect: dropshadow(gaussian, rgba(123,47,247,0.2), 15, 0, 0, 5);">

                            <!-- En-tête de carte avec dégradé -->
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <StackPane style="-fx-background-color: #F0E6FF; -fx-background-radius: 12; -fx-padding: 8;">
                                    <Label text="➕" style="-fx-font-size: 20px; -fx-text-fill: #7B2FF7;"/>
                                </StackPane>
                                <Label text="Ajouter un nouveau cours"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #7B2FF7;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Tous les champs marqués * sont obligatoires"
                                       style="-fx-text-fill: #999; -fx-font-size: 11px; -fx-font-style: italic;"/>
                            </HBox>

                            <Separator style="-fx-background-color: #F0E6FF; -fx-pref-height: 2;"/>

                            <!-- Titre du cours -->
                            <VBox spacing="5">
                                <Label text="📝 Titre du cours *"
                                       style="-fx-font-weight: bold; -fx-text-fill: #555; -fx-font-size: 14px;"/>
                                <TextField fx:id="titreField"
                                           promptText="Ex: Introduction à la communication sociale"
                                           style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 12; -fx-background-color: #F8F9FA; -fx-border-color: #E0E0E0; -fx-border-width: 1;"/>
                                <!-- L'erreur sera ajoutée ici dynamiquement -->
                            </VBox>

                            <!-- Type et Niveau -->
                            <HBox spacing="15">
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label text="📊 Type de cours *"
                                           style="-fx-font-weight: bold; -fx-text-fill: #555; -fx-font-size: 14px;"/>
                                    <ComboBox fx:id="typeCoursCombo"
                                              prefWidth="200"
                                              promptText="Sélectionnez un type"
                                              style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 8; -fx-background-color: #F8F9FA; -fx-border-color: #E0E0E0;"/>
                                </VBox>

                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label text="📈 Niveau *"
                                           style="-fx-font-weight: bold; -fx-text-fill: #555; -fx-font-size: 14px;"/>
                                    <ComboBox fx:id="niveauCombo"
                                              prefWidth="200"
                                              promptText="Sélectionnez un niveau"
                                              style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 8; -fx-background-color: #F8F9FA; -fx-border-color: #E0E0E0;"/>
                                </VBox>
                            </HBox>

                            <!-- Durée -->
                            <VBox spacing="5">
                                <Label text="⏱️ Durée (minutes) *"
                                       style="-fx-font-weight: bold; -fx-text-fill: #555; -fx-font-size: 14px;"/>
                                <TextField fx:id="dureeField"
                                           promptText="Ex: 120"
                                           style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 12; -fx-background-color: #F8F9FA; -fx-border-color: #E0E0E0;"/>
                            </VBox>

                            <!-- Description -->
                            <VBox spacing="5">
                                <Label text="📄 Description *"
                                       style="-fx-font-weight: bold; -fx-text-fill: #555; -fx-font-size: 14px;"/>
                                <TextArea fx:id="descriptionArea"
                                          promptText="Décrivez votre cours..."
                                          prefRowCount="4"
                                          wrapText="true"
                                          style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 12; -fx-background-color: #F8F9FA; -fx-border-color: #E0E0E0;"/>
                            </VBox>

                            <!-- Image du cours -->
                            <VBox spacing="5">
                                <Label text="🖼️ Image du cours *"
                                       style="-fx-font-weight: bold; -fx-text-fill: #555; -fx-font-size: 14px;"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <TextField fx:id="imageField"
                                               promptText="Nom du fichier image"
                                               HBox.hgrow="ALWAYS"
                                               style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 12; -fx-background-color: #F8F9FA; -fx-border-color: #E0E0E0;"/>
                                    <Button fx:id="parcourirImageButton"
                                            text="📁 Parcourir..."
                                            style="-fx-background-color: #7B2FF7;
                                                   -fx-text-fill: white;
                                                   -fx-background-radius: 15;
                                                   -fx-padding: 12 20;
                                                   -fx-cursor: hand;
                                                   -fx-font-weight: bold;
                                                   -fx-effect: dropshadow(gaussian, rgba(123,47,247,0.3), 5, 0, 0, 2);"/>
                                </HBox>
                            </VBox>

                            <!-- Section Mots avec fond coloré -->
                            <VBox spacing="15"
                                  style="-fx-background-color: #F8F0FF; -fx-background-radius: 20; -fx-padding: 20; -fx-border-color: #7B2FF7; -fx-border-width: 1; -fx-border-radius: 20;">

                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <StackPane style="-fx-background-color: #7B2FF7; -fx-background-radius: 10; -fx-padding: 5;">
                                        <Label text="🔤" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                                    </StackPane>
                                    <Label text="Mots du cours *"
                                           style="-fx-font-weight: bold; -fx-text-fill: #7B2FF7; -fx-font-size: 16px;"/>
                                    <Label text="(séparés par ;)"
                                           style="-fx-text-fill: #999; -fx-font-size: 12px; -fx-font-style: italic;"/>
                                </HBox>

                                <VBox spacing="5">
                                    <TextArea fx:id="motsField"
                                              promptText="Ex: LE CHOCOLAT;LES TOILETTES;LA PELUCHE;LE BALLON"
                                              prefRowCount="2"
                                              style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 12; -fx-background-color: white; -fx-border-color: #7B2FF7; -fx-border-width: 1;"/>
                                </VBox>
                            </VBox>

                            <!-- Section Images avec fond coloré -->
                            <VBox spacing="15"
                                  style="-fx-background-color: #F0F7FF; -fx-background-radius: 20; -fx-padding: 20; -fx-border-color: #3498DB; -fx-border-width: 1; -fx-border-radius: 20;">

                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <StackPane style="-fx-background-color: #3498DB; -fx-background-radius: 10; -fx-padding: 5;">
                                        <Label text="🖼️" style="-fx-font-size: 16px; -fx-text-fill: white;"/>
                                    </StackPane>
                                    <Label text="Images pour chaque mot"
                                           style="-fx-font-weight: bold; -fx-text-fill: #3498DB; -fx-font-size: 16px;"/>
                                    <Label text="(plusieurs images par mot séparées par ;)"
                                           style="-fx-text-fill: #999; -fx-font-size: 12px; -fx-font-style: italic;"/>
                                </HBox>

                                <!-- Conteneur pour les lignes d'images -->
                                <VBox fx:id="imagesMotsContainer" spacing="10">
                                    <!-- Les lignes seront ajoutées dynamiquement -->
                                </VBox>

                                <!-- Bouton pour ajouter une ligne -->
                                <Button fx:id="ajouterLigneImageButton"
                                        text="+ Ajouter des images pour un mot"
                                        style="-fx-background-color: transparent;
                                               -fx-border-color: #3498DB;
                                               -fx-border-width: 2;
                                               -fx-text-fill: #3498DB;
                                               -fx-border-radius: 15;
                                               -fx-background-radius: 15;
                                               -fx-padding: 12 20;
                                               -fx-cursor: hand;
                                               -fx-font-weight: bold;
                                               -fx-effect: dropshadow(gaussian, rgba(52,152,219,0.2), 5, 0, 0, 2);"/>
                            </VBox>

                            <!-- Barre de progression (indicateur) -->
                            <HBox alignment="CENTER" spacing="10">
                                <Label text="Complétude du formulaire:" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>
                                <ProgressBar fx:id="completionProgress" progress="0.0" prefWidth="200"/>
                                <Label fx:id="completionLabel" text="0%" style="-fx-text-fill: #7B2FF7; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                            </HBox>

                            <Separator/>

                            <!-- Boutons d'action avec design amélioré -->
                            <HBox spacing="15" alignment="CENTER_RIGHT">
                                <Button text="👁 Voir les cours"
                                        fx:id="voirCoursButton"
                                        style="-fx-background-color: transparent;
                                               -fx-border-color: #7B2FF7;
                                               -fx-border-width: 2;
                                               -fx-text-fill: #7B2FF7;
                                               -fx-border-radius: 25;
                                               -fx-background-radius: 25;
                                               -fx-padding: 12 25;
                                               -fx-cursor: hand;
                                               -fx-font-weight: bold;"/>

                                <Button text="📋 Todo List"
                                        fx:id="todoButton"
                                        style="-fx-background-color: #FF9800;
                                               -fx-text-fill: white;
                                               -fx-background-radius: 25;
                                               -fx-padding: 12 25;
                                               -fx-cursor: hand;
                                               -fx-font-weight: bold;
                                               -fx-effect: dropshadow(gaussian, rgba(255,152,0,0.4), 8, 0, 0, 2);"/>

                                <Region HBox.hgrow="ALWAYS" />

                                <Button text="❌ Annuler"
                                        fx:id="annulerButton"
                                        style="-fx-background-color: transparent;
                                               -fx-border-color: #FF4444;
                                               -fx-text-fill: #FF4444;
                                               -fx-border-width: 2;
                                               -fx-border-radius: 25;
                                               -fx-background-radius: 25;
                                               -fx-padding: 12 25;
                                               -fx-cursor: hand;
                                               -fx-font-weight: bold;"/>

                                <Button text="✅ Ajouter le cours"
                                        fx:id="ajouterButton"
                                        style="-fx-background-color: linear-gradient(to right, #7B2FF7, #9F5FF7);
                                               -fx-text-fill: white;
                                               -fx-background-radius: 25;
                                               -fx-padding: 12 30;
                                               -fx-cursor: hand;
                                               -fx-font-weight: bold;
                                               -fx-font-size: 14px;
                                               -fx-effect: dropshadow(gaussian, rgba(123,47,247,0.4), 10, 0, 0, 3);"/>
                            </HBox>
                        </VBox>

                        <!-- ================= CARTE LISTE DES COURS AMÉLIORÉE ================= -->
                        <VBox spacing="15"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 25;
                                     -fx-border-radius: 25;
                                     -fx-border-color: #7B2FF7;
                                     -fx-border-width: 2;
                                     -fx-padding: 25;
                                     -fx-effect: dropshadow(gaussian, rgba(123,47,247,0.15), 15, 0, 0, 5);">

                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <StackPane style="-fx-background-color: #F0E6FF; -fx-background-radius: 12; -fx-padding: 8;">
                                    <Label text="📋" style="-fx-font-size: 20px; -fx-text-fill: #7B2FF7;"/>
                                </StackPane>
                                <Label text="Liste des cours disponibles"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #7B2FF7;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="coursCountLabel" text="0 cours"
                                       style="-fx-background-color: #7B2FF7; -fx-text-fill: white; -fx-padding: 5 15; -fx-background-radius: 20; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                            </HBox>

                            <Separator style="-fx-background-color: #F0E6FF;"/>

                            <TableView fx:id="coursTable" prefHeight="300"
                                       style="-fx-background-radius: 15; -fx-border-radius: 15;">
                                <columns>
                                    <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
                                    <TableColumn fx:id="titreColumn" text="Titre" prefWidth="200"/>
                                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="150"/>
                                    <TableColumn fx:id="niveauColumn" text="Niveau" prefWidth="120"/>
                                    <TableColumn fx:id="dureeColumn" text="Durée (min)" prefWidth="100"/>
                                    <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="250"/>
                                    <TableColumn fx:id="imageColumn" text="Image" prefWidth="100"/>
                                    <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="150"/>
                                </columns>
                            </TableView>
                        </VBox>

                        <!-- Pied de page -->
                        <HBox alignment="CENTER" spacing="10">
                            <Label text="✨" style="-fx-font-size: 14px;"/>
                            <Label text="Toutes les modifications sont automatiquement sauvegardées"
                                   style="-fx-text-fill: #999; -fx-font-size: 12px;"/>
                        </HBox>

                    </VBox>
                </content>
            </ScrollPane>
        </HBox>
    </children>
</AnchorPane>