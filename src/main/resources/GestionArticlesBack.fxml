<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane fx:id="root"
            stylesheets="@styles/app.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auticare.Controller.GestionArticlesBackController">

    <!-- ================= SIDEBAR (copie exacte du Psychologue) ================= -->
    <left>
        <VBox prefWidth="220"
              minWidth="220"
              maxWidth="220"
              spacing="8"
              style="-fx-background-color: linear-gradient(to bottom, #7B2FF7, #5F0FFF); -fx-padding: 20 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 8, 0, 0, 5);">

            <!-- Logo compact -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 12 0;">
                <ImageView fitHeight="32" fitWidth="32" preserveRatio="true">
                    <Image url="@assets/logo.png" />
                </ImageView>
                <VBox spacing="1">
                    <Label text="AutiCare" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="Psychologue" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Separator style="-fx-background-color: rgba(255,255,255,0.2); -fx-pref-height: 1;"/>

            <!-- Profil compact -->
            <VBox alignment="CENTER" spacing="8" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-padding: 12;">
                <Circle radius="25" fill="white" />
                <VBox alignment="CENTER" spacing="1">
                    <Label fx:id="userNameLabel" text="Psychologue"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <Label fx:id="userEmailLabel" text="psychologue@test.com"
                           style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 10px;"/>
                </VBox>
            </VBox>

            <!-- Menu principal (actions conservées) -->
            <VBox spacing="4" style="-fx-padding: 8 0;">
                <!-- Dashboard (actif) -->
                <Button text="🏠 Dashboard"
                        styleClass="sidebar-button, sideBtnActive"
                        maxWidth="Infinity"
                        onAction="#showDashboard"/>

                <!-- Mon Profil -->
                <Button text="👤 Mon Profil"
                        styleClass="sidebar-button, sideBtnActive"
                        maxWidth="Infinity"
                        onAction="#goToProfile"/>

                <!-- Emploi du temps -->
                <Button text="📅 Emploi du temps"
                        styleClass="sidebar-button, sideBtnActive"
                        maxWidth="Infinity"
                        onAction="#showSchedule"/>

                <!-- Rendez-vous -->
                <Button text="📆 Rendez-vous"
                        styleClass="sidebar-button, sideBtnActive"
                        maxWidth="Infinity"
                        onAction="#showAppointments"/>

                <!-- Suivi thérapeutique -->
                <Button text="📊 Suivi thérapeutique"
                        styleClass="sidebar-button, sideBtnActive"
                        maxWidth="Infinity"
                        onAction="#showTherapeuticFollowUp"/>

                <!-- Thérapies -->
                <Button text="🧠 Thérapies"
                        styleClass="sidebar-button, sideBtnActive"
                        maxWidth="Infinity"
                        onAction="#showTherapies"/>

                <!-- Articles & Conseils -->
                <Button text="📚 Articles &amp; Conseils"
                        styleClass="sidebar-button, sideBtnActive"
                        style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: rgba(255,255,255,0.8); -fx-cursor: hand; -fx-padding: 8 12; -fx-alignment: CENTER_LEFT; -fx-font-size: 13px; -fx-background-radius: 8;"
                        maxWidth="Infinity"
                        onAction="#showArticles"/>

                <!-- Événements -->
                <Button text="🎉 Événements"
                        styleClass="sidebar-button, sideBtnActive"
                        maxWidth="Infinity"
                        onAction="#showEvents"/>
            </VBox>

            <VBox VBox.vgrow="ALWAYS" />

            <!-- Déconnexion -->
            <Button fx:id="logoutBtn" text="🚪 Déconnexion"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: #ffb4b4; -fx-cursor: hand; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT;"
                    maxWidth="Infinity"
                    onAction="#handleLogout"/>
        </VBox>
    </left>

    <!-- ✅ CONTENT (inchangé) -->
    <center>
        <StackPane styleClass="pageBg">

            <!-- SCROLL -->
            <ScrollPane fx:id="mainScroll"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        pannable="true"
                        styleClass="pageScroll">
                <content>
                    <VBox spacing="16" styleClass="page" maxWidth="1200">

                        <!-- TopBar -->
                        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbarBox">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Gestion des Articles" styleClass="h1"/>
                                <Label text="Ajoutez / modifiez / supprimez les articles &amp; conseils." styleClass="sub"/>
                            </VBox>

                            <TextField fx:id="searchField"
                                       promptText="Rechercher un article..."
                                       styleClass="searchField"/>
                        </HBox>

                        <!-- Count -->
                        <HBox alignment="CENTER_LEFT">
                            <Label fx:id="countLabel" text="0 Articles" styleClass="count"/>
                        </HBox>

                        <!-- ✅ Empty séparé (IMPORTANT) -->
                        <VBox fx:id="emptyBox"
                              managed="false"
                              visible="false"
                              spacing="6"
                              styleClass="emptyCard">
                            <Label text="Aucun article trouvé" styleClass="emptyTitle"/>
                            <Label text="Essayez une autre recherche ou ajoutez un article." styleClass="emptySub"/>
                        </VBox>

                        <!-- Cards -->
                        <VBox styleClass="cardsFrame">
                            <FlowPane fx:id="cardsPane"
                                      alignment="TOP_CENTER"
                                      hgap="20"
                                      vgap="20"
                                      prefWrapLength="1100"
                                      styleClass="cardsWrap"/>
                        </VBox>

                    </VBox>
                </content>
            </ScrollPane>

            <!-- ✅ FABs bottom-right (UNE SEULE ZONE) -->
            <VBox spacing="14"
                  alignment="CENTER_RIGHT"
                  StackPane.alignment="CENTER_RIGHT"
                  pickOnBounds="false">
                <StackPane.margin>
                    <Insets top="0" right="26" bottom="26" left="0"/>
                </StackPane.margin>

                <Button fx:id="btnAjouterFab" text="＋" styleClass="fabAdd"/>
                <Button fx:id="btnFrontOfficeFab" text="🌐" styleClass="fabFront"/>
            </VBox>

        </StackPane>
    </center>
</BorderPane>