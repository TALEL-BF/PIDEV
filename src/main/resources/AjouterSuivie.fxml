<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.StackedBarChart?>
<BorderPane fx:id="root"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auticare.Controller.AjouterSuivie"
            stylesheets="@styles/app.css">

    <!-- ================= SIDEBAR (copie exacte du Psychologue) ================= -->
    <left>
        <VBox prefWidth="220"
              minWidth="220"
              maxWidth="220"
              spacing="8"
              style="-fx-background-color: linear-gradient(to bottom, #7B2FF7, #5F0FFF); -fx-padding: 20 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 8, 0, 0, 5);">

            <!-- Logo compact -->
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 12 0;">
                <ImageView fitHeight="32" fitWidth="32" preserveRatio="true">
                    <Image url="@assets/logo.png" />
                </ImageView>
                <VBox spacing="1">
                    <Label text="AutiCare" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="Psychologue" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Separator style="-fx-background-color: rgba(255,255,255,0.2); -fx-pref-height: 1;"/>

            <!-- Profil compact -->
            <VBox alignment="CENTER" spacing="8" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-padding: 12;">
                <Circle radius="25" fill="white" />
                <VBox alignment="CENTER" spacing="1">
                    <Label fx:id="userNameLabel" text="Psychologue"
                           style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <Label fx:id="userEmailLabel" text="psychologue@test.com"
                           style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 10px;"/>
                </VBox>
            </VBox>

            <!-- Menu principal (actions conservées) -->
            <VBox spacing="4" style="-fx-padding: 8 0;">
                <!-- Dashboard (actif) -->
                <Button text="🏠 Dashboard"
                        styleClass="sidebar-button, sideBtnActive"
                        maxWidth="Infinity"
                        onAction="#showDashboard"/>

                <!-- Mon Profil -->
                <Button text="👤 Mon Profil"
                        styleClass="sidebar-button, sideBtnActive"
                        maxWidth="Infinity"
                        onAction="#goToProfile"/>

                <!-- Emploi du temps -->
                <Button text="📅 Emploi du temps"
                        styleClass="sidebar-button, sideBtnActive"
                        maxWidth="Infinity"
                        onAction="#showSchedule"/>

                <!-- Rendez-vous -->
                <Button text="📆 Rendez-vous"
                        styleClass="sidebar-button, sideBtnActive"
                        maxWidth="Infinity"
                        onAction="#showAppointments"/>

                <!-- Suivi thérapeutique -->
                <Button text="📊 Suivi thérapeutique"
                        styleClass="sidebar-button, sideBtnActive"
                        style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: rgba(255,255,255,0.8); -fx-cursor: hand; -fx-padding: 8 12; -fx-alignment: CENTER_LEFT; -fx-font-size: 13px; -fx-background-radius: 8;"
                        maxWidth="Infinity"
                        onAction="#showTherapeuticFollowUp"/>

                <!-- Thérapies -->
                <Button text="🧠 Thérapies"
                        styleClass="sidebar-button, sideBtnActive"
                        maxWidth="Infinity"
                        onAction="#showTherapies"/>

                <!-- Articles & Conseils -->
                <Button text="📚 Articles &amp; Conseils"
                        styleClass="sidebar-button, sideBtnActive"
                        maxWidth="Infinity"
                        onAction="#showArticles"/>

                <!-- Événements -->
                <Button text="🎉 Événements"
                        styleClass="sidebar-button, sideBtnActive"
                        maxWidth="Infinity"
                        onAction="#showEvents"/>
            </VBox>

            <VBox VBox.vgrow="ALWAYS" />

            <!-- Déconnexion -->
            <Button fx:id="logoutBtn" text="🚪 Déconnexion"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: #ffb4b4; -fx-cursor: hand; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-size: 13px; -fx-alignment: CENTER_LEFT;"
                    maxWidth="Infinity"
                    onAction="#handleLogout"/>
        </VBox>
    </left>

    <!-- ================= CONTENU PRINCIPAL (inchangé) ================= -->
    <center>
        <StackPane styleClass="pageBg">

            <ScrollPane fx:id="mainScroll"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        pannable="true"
                        styleClass="pageScroll">
                <content>
                    <VBox spacing="16" styleClass="page" maxWidth="1200">

                        <!-- Top Bar -->
                        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbar">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Gestion des Suivies" styleClass="h1"/>
                                <Label text="Gérez les suivies et les informations associées" styleClass="sub"/>
                            </VBox>

                            <TextField fx:id="searchField" promptText="Rechercher un suivi..." styleClass="searchField"/>

                            <Button fx:id="btnAjouter" text="+ Ajouter" styleClass="btnPrimary"
                                    visible="false" managed="false"/>
                        </HBox>

                        <!-- Stats -->
                        <VBox spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="statsToggleRow">
                                <Label fx:id="lblToggleStats" text="▸ Statistiques" styleClass="statsToggleText"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <StackPane styleClass="notifWrap">
                                    <Button fx:id="btnNotif" text="🔔" styleClass="notifBtn"/>
                                    <Label fx:id="lblNotifBadge" text="0" styleClass="notifBadge"
                                           visible="false" managed="false"
                                           StackPane.alignment="TOP_RIGHT"/>
                                </StackPane>
                                <Label text="Aperçu rapide" styleClass="statsHint"/>
                            </HBox>

                            <VBox fx:id="statsBox" managed="false" visible="false" spacing="12" styleClass="statsShell">
                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="statsHeader">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label text="Tableau de bord" styleClass="statsHeaderTitle"/>
                                        <Label text="Évolution mensuelle + deltas par enfant" styleClass="statsHeaderSub"/>
                                    </VBox>
                                    <ComboBox fx:id="cbEnfantStats" promptText="Choisir un enfant..." styleClass="statsCombo"/>
                                    <Button fx:id="btnRefreshStats" text="Actualiser" styleClass="statsBtn"/>
                                </HBox>

                                <VBox spacing="14" styleClass="statsBody" VBox.vgrow="ALWAYS">
                                    <VBox spacing="8" VBox.vgrow="ALWAYS" styleClass="chartShell">
                                        <HBox alignment="CENTER_LEFT">
                                            <Label text="Tendance mensuelle" styleClass="chartTitle"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Label text="Moyennes" styleClass="chartHint"/>
                                        </HBox>
                                        <VBox spacing="8" VBox.vgrow="ALWAYS" styleClass="chartShell">
                                            <HBox alignment="CENTER_LEFT">
                                                <Label text="Comparatif mensuel" styleClass="chartTitle"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Label text="H / S / A" styleClass="chartHint"/>
                                            </HBox>
                                            <LineChart fx:id="lineConsultations" VBox.vgrow="ALWAYS" minHeight="420">
                                                <xAxis><NumberAxis fx:id="xAxisStats"/></xAxis>
                                                <yAxis><NumberAxis fx:id="yAxisStats"/></yAxis>
                                            </LineChart>
                                        </VBox>
                                    </VBox>

                                    <GridPane hgap="12" vgap="12" styleClass="kpiRow">
                                        <columnConstraints>
                                            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                                            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                                            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                                            <ColumnConstraints percentWidth="25" hgrow="ALWAYS"/>
                                        </columnConstraints>
                                        <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="kpiMini">
                                            <Label text="Δ Humeur" styleClass="kpiMiniK"/>
                                            <Label fx:id="lblDeltaHumeur" text="-" styleClass="kpiMiniV"/>
                                            <Label text="Dernier mois vs précédent" styleClass="kpiMiniS"/>
                                        </VBox>
                                        <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="kpiMini">
                                            <Label text="Δ Stress" styleClass="kpiMiniK"/>
                                            <Label fx:id="lblDeltaStress" text="-" styleClass="kpiMiniV"/>
                                            <Label text="Plus haut = amélioration" styleClass="kpiMiniS"/>
                                        </VBox>
                                        <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="2" styleClass="kpiMini">
                                            <Label text="Δ Attention" styleClass="kpiMiniK"/>
                                            <Label fx:id="lblDeltaAttention" text="-" styleClass="kpiMiniV"/>
                                            <Label text="Dernier mois vs précédent" styleClass="kpiMiniS"/>
                                        </VBox>
                                        <VBox spacing="6" GridPane.rowIndex="0" GridPane.columnIndex="3" styleClass="kpiMiniSoft">
                                            <Label text="Astuce" styleClass="kpiMiniK"/>
                                            <Label text="Choisis un enfant puis Actualiser" styleClass="kpiMiniSoftText" wrapText="true"/>
                                        </VBox>
                                    </GridPane>
                                </VBox>
                            </VBox>
                        </VBox>

                        <!-- Count -->
                        <HBox alignment="CENTER_LEFT">
                            <Label fx:id="countLabel" text="0 Suivies" styleClass="count"/>
                        </HBox>

                        <!-- Empty -->
                        <VBox fx:id="emptyBox" managed="false" visible="false" spacing="6" styleClass="emptyCard">
                            <Label text="Aucun suivi trouvé" styleClass="emptyTitle"/>
                            <Label text="Essayez une autre recherche ou ajoutez un suivi." styleClass="emptySub"/>
                        </VBox>

                        <!-- Cards -->
                        <VBox styleClass="cardsContainer">
                            <FlowPane fx:id="cardsPane"
                                      alignment="CENTER"
                                      hgap="20"
                                      vgap="20"
                                      prefWrapLength="1100"
                                      styleClass="cardsWrap"/>
                        </VBox>

                    </VBox>
                </content>
            </ScrollPane>

            <!-- FAB -->
            <Button fx:id="btnAjouterFab"
                    text="＋"
                    styleClass="fabAdd"
                    StackPane.alignment="CENTER_RIGHT">
                <StackPane.margin><Insets top="0" right="24" bottom="0" left="0"/></StackPane.margin>
            </Button>

        </StackPane>
    </center>
</BorderPane>