<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="Controller.EmploiCardsController"
      spacing="14" style="-fx-background-color: #f3e8ff;">

    <!-- Title -->
    <VBox spacing="3">
        <Label text="Emploi du Temps 🕐" styleClass="page-title" style="-fx-text-fill: #5b21b6;"/>
        <Label text="Vos plannings hebdomadaires" styleClass="page-subtitle" style="-fx-text-fill: #7c3aed;"/>
    </VBox>

    <!-- Filters + Add Button -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Filtrer par:" style="-fx-font-weight: 700; -fx-font-size: 13; -fx-text-fill: #4c1d95;"/>

        <ComboBox fx:id="filterJour" promptText="Jour"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 8 16; -fx-border-color: #ddd6fe; -fx-border-width: 2; -fx-border-radius: 12;"/>

        <ComboBox fx:id="filterTranche" promptText="Tranche horaire"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 8 16; -fx-border-color: #ddd6fe; -fx-border-width: 2; -fx-border-radius: 12;"/>

        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <Label fx:id="countLabel" text="0 Emplois" styleClass="count" style="-fx-text-fill: #6d28d9;"/>

    <!-- Cards grid -->
    <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
        <FlowPane fx:id="cardsPane" hgap="18" vgap="18" prefWrapLength="980">
            <padding>
                <Insets bottom="20"/>
            </padding>
        </FlowPane>
    </ScrollPane>

</VBox>
