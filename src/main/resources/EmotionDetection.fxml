<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.EmotionDetection"
            stylesheets="@styles/app.css"
            prefWidth="1508" prefHeight="848"
            style="-fx-background-color: #E6F0FF;">  <!-- Changed to light blue background -->

    <!-- ========== SIDEBAR ========== -->
    <left>
        <!-- Sidebar sans effet de lumière -->
        <VBox prefWidth="240.0"
              minWidth="240.0"
              maxWidth="240.0"
              spacing="15"
              style="-fx-background-color: linear-gradient(to bottom, #7B2FF7, #5F0FFF); -fx-padding: 20 15;">

            <!-- Logo + Titre -->
            <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 5 0 10 0;">
                <ImageView fitWidth="65" fitHeight="65" preserveRatio="true">
                    <image>
                        <Image url="@assets/logo.png"/>
                    </image>
                </ImageView>
                <VBox>
                    <Label text="AutiCare" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 900;"/>
                    <Label text="✨ Plateforme éducative ✨" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 12px; -fx-font-style: italic;"/>
                </VBox>
            </HBox>

            <!-- Connecté en tant qu'étudiant -->
            <VBox spacing="4" style="-fx-padding: 5 0 5 0;">
                <Label text="Connecté en tant que" style="-fx-text-fill: #F0E6FF; -fx-font-size: 13px; -fx-font-weight: 600;"/>
                <Label text="👤 Élève Magicien"
                       style="-fx-background-color: rgba(255,255,255,0.2);
                          -fx-text-fill: white;
                          -fx-padding: 8 15;
                          -fx-background-radius: 30;
                          -fx-font-weight: bold;
                          -fx-font-size: 15px;
                          -fx-border-color: white;
                          -fx-border-width: 1;
                          -fx-border-radius: 30;"/>
            </VBox>

            <Separator style="-fx-background-color: rgba(255,255,255,0.2); -fx-padding: 5 0;"/>

            <!-- Menu -->
            <VBox spacing="8" style="-fx-padding: 5 0;">
                <Button text="📚 Nos cours"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-background-radius: 12;
                           -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand;"/>

                <Button text="🗓️ Emploi du temps"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-background-radius: 12;
                           -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand;"/>

                <Button text="🩺 Nos consultations"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-background-radius: 12;
                           -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand; -fx-wrap-text: true;"/>

                <!-- Événements en surbrillance (légèrement plus visible) -->
                <Button text="🎉 Nos événements"
                        style="-fx-background-color: rgba(255,255,255,0.3); -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-background-radius: 12;
                           -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;"/>

                <Button text="🎮 Nos jeux éducatifs"
                        style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 10 15; -fx-background-radius: 12;
                           -fx-font-size: 14px; -fx-font-weight: 600; -fx-cursor: hand;"/>
            </VBox>

            <VBox VBox.vgrow="ALWAYS" />

            <!-- Déconnexion - plus petite et sans effet -->
            <Button text="Déconnexion"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 8 15; -fx-background-radius: 12;
                       -fx-font-size: 13px; -fx-font-weight: 600; -fx-cursor: hand;"/>

            <!-- Message inspirant -->
            <Label text="💫Un espace pensé pour chaque autiste💫"
                   wrapText="true"
                   style="-fx-text-fill: #E0D7FF; -fx-font-size: 12px; -fx-font-style: italic;
                      -fx-padding: 10 0 5 0;
                      -fx-alignment: CENTER;"/>
        </VBox>
    </left>

    <!-- ========== MAIN CONTENT ========== -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="5" alignment="TOP_CENTER"
                  style="-fx-padding: 5 30; -fx-background-color: transparent;">

                <!-- Bouton retour -->
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 0;">
                    <Button fx:id="backButton"
                            text="← Retour"
                            onAction="#goBackToShowEvent"
                    style="-fx-background-color: #f8f9fa; -fx-text-fill: #7B2FF7;
                    -fx-background-radius: 30; -fx-padding: 8 20;
                    -fx-cursor: hand; -fx-border-color: #d0c4ff;
                    -fx-border-radius: 30; -fx-border-width: 1;"/>
                </HBox>

                <!-- TITRE AVEC IMAGES MICRO -->
                <HBox spacing="15" alignment="CENTER">
                    <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
                        <image>
                            <Image url="@assets/bf.png"/>
                        </image>
                    </ImageView>
                    <Label text="🎤 Comment te sens-tu aujourd'hui ?"
                           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #7B2FF7;"/>
                    <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
                        <image>
                            <Image url="@assets/micro.png"/>
                        </image>
                    </ImageView>
                </HBox>

                <!-- ========== GRANDE CARTE PRINCIPALE ========== -->
                <VBox spacing="0" alignment="CENTER"
                      fx:id="mainCard"
                      style="-fx-background-color: white;
                             -fx-background-radius: 30;
                             -fx-border-color: #7B2FF7;
                             -fx-border-width: 3;
                             -fx-border-radius: 30;
                             -fx-effect: dropshadow(gaussian, rgba(123,47,247,0.2), 20, 0, 0, 8);
                             -fx-min-height: 700;
                             -fx-max-width: 1150;">

                    <!-- SCROLLPANE À L'INTÉRIEUR DE LA CARTE -->
                    <ScrollPane fitToWidth="true" fitToHeight="true"
                                style="-fx-background-color: transparent; -fx-border-color: transparent;
                                       -fx-background: transparent; -fx-padding: 0;">
                        <VBox spacing="25" alignment="CENTER"
                              style="-fx-padding: 35; -fx-background-color: transparent; -fx-max-width: 1100;">

                            <!-- BOUTON AVEC EMOJI -->
                            <Button fx:id="recordButton" text="🎤 Parler maintenant"
                                    onAction="#onRecordClick"
                                    style="-fx-background-color: #7B2FF7; -fx-text-fill: white;
                                           -fx-font-size: 18px; -fx-font-weight: bold;
                                           -fx-background-radius: 40; -fx-padding: 12 30;
                                           -fx-cursor: hand;
                                           -fx-effect: dropshadow(gaussian, rgba(123,47,247,0.3), 8, 0, 0, 3);"/>

                            <!-- Statut -->
                            <Label fx:id="statusLabel" text="Appuie sur le bouton pour commencer"
                                   style="-fx-font-size: 18px; -fx-text-fill: #6B7280; -fx-font-style: italic;"/>

                            <!-- Résultat émotion -->
                            <Label fx:id="emotionLabel" text=""
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #7B2FF7;"/>

                            <!-- Barre de confiance -->
                            <ProgressBar fx:id="confidenceBar" prefWidth="500" progress="0"
                                         style="-fx-accent: #7B2FF7; -fx-pref-height: 15;"/>

                            <!-- SECTION ÉVÉNEMENTS RECOMMANDÉS -->
                            <VBox spacing="20" style="-fx-pref-width: 1050;">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <!-- Remplacement de l'emoji calendrier par une image -->
                                    <ImageView fitWidth="51" fitHeight="51" preserveRatio="true">
                                        <image>
                                            <Image url="@assets/thinking.png"/>
                                        </image>
                                    </ImageView>
                                    <Label text="Selon ton humeur, on te propose :"
                                           style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: #7B2FF7;"/>
                                </HBox>

                                <!-- Conteneur des cartes d'événements -->
                                <VBox fx:id="eventsContainer" spacing="15" alignment="CENTER"/>
                            </VBox>

                            <!-- SECTION CONSEIL AVEC IMAGE -->
                            <VBox spacing="15" style="-fx-pref-width: 1050; -fx-padding: 15 0 30 0;">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
                                        <image>
                                            <Image url="@assets/conseil.png"/>
                                        </image>
                                    </ImageView>
                                    <Label text="Notre conseil pour toi :"
                                           style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: #7B2FF7;"/>
                                </HBox>

                                <Label fx:id="conseilLabel"
                                       wrapText="true"
                                       maxWidth="1050"
                                       minHeight="120"
                                       prefHeight="150"
                                       style="-fx-font-size: 18px; -fx-padding: 25; -fx-background-color: #F5F0FF;
              -fx-background-radius: 25; -fx-text-fill: #374151;
              -fx-border-color: #E5D9FF; -fx-border-width: 2; -fx-border-radius: 25;
              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 8, 0, 0, 3);"/>
                            </VBox>

                            <!-- Petit espace en bas -->
                            <Region prefHeight="20"/>
                        </VBox>
                    </ScrollPane>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>