<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="Controller.EmploiManagementController"
      spacing="14">

    <!-- Title -->
    <VBox spacing="3">
        <Label text="Emploi du Temps 🕐" styleClass="page-title"/>
        <Label text="Gérez les emplois du temps et plannings hebdomadaires" styleClass="page-subtitle"/>
    </VBox>

    <!-- Filters + Add Button -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Filtrer par:" style="-fx-font-weight: 700; -fx-font-size: 13; -fx-text-fill: #4b5563;"/>

        <ComboBox fx:id="filterJour" promptText="Jour"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 8 16; -fx-border-color: #d1fae5; -fx-border-width: 2; -fx-border-radius: 12;"/>

        <ComboBox fx:id="filterTranche" promptText="Tranche horaire"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 8 16; -fx-border-color: #d1fae5; -fx-border-width: 2; -fx-border-radius: 12;"/>

        <Button text="🗓️ Vue Calendrier" onAction="#switchToCalendar"
                style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 8 16; -fx-font-weight: 600;"/>


        <Region HBox.hgrow="ALWAYS"/>

        <Button text="➕ Nouvel Emploi" onAction="#addNewEmploi"
                style="-fx-background-color: linear-gradient(to right, #10b981, #059669); -fx-text-fill: white; -fx-background-radius: 12; -fx-padding: 10 20; -fx-font-weight: 700; -fx-font-size: 14; -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.4), 12, 0, 0, 4);"/>
    </HBox>

    <Label fx:id="countLabel" text="0 Emplois" styleClass="count"/>

    <!-- Table View -->
    <TableView fx:id="emploiTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
        <columns>
            <TableColumn fx:id="colAnnee" text="Année Scolaire"/>
            <TableColumn fx:id="colJour" text="Jour"/>
            <TableColumn fx:id="colTranche" text="Tranche Horaire"/>
            <TableColumn fx:id="colActivite" text="Activité (RDV / Séance)"/>
            <TableColumn fx:id="colActions" text="Actions"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

</VBox>

