<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainContainer" prefHeight="800.0" prefWidth="1200.0" styleClass="main-bg"
            stylesheets="@../styles.css" xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auticare.controller.AdminDashboardController">

    <!-- ===== SIDEBAR MODERNE ===== -->
    <left>
        <VBox prefWidth="280.0"
              minWidth="280.0"
              maxWidth="280.0"
              spacing="15"
              style="-fx-background-color: linear-gradient(to bottom, #667eea, #764ba2); -fx-padding: 30 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5);"
              BorderPane.alignment="CENTER">

            <!-- ===== LOGO AVEC IMAGE ===== -->
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 0 0 20 5;">
                <ImageView fitHeight="50.0" fitWidth="50.0" preserveRatio="true">
                    <image>
                        <Image url="@../images/logo.jpg"/>
                    </image>
                </ImageView>

                <VBox spacing="3">
                    <Label text="AutiCare" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold; -fx-font-family: 'Poppins';"/>
                    <Label text="Espace éducatif" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px; -fx-font-family: 'Poppins';"/>
                </VBox>
            </HBox>

            <!-- ===== SÉPARATEUR ÉLÉGANT ===== -->
            <Separator style="-fx-background-color: rgba(255,255,255,0.15); -fx-pref-height: 1;"/>

            <!-- ===== MENU DE NAVIGATION ===== -->
            <VBox spacing="8" style="-fx-padding: 15 0 20 0;">

                <!-- Gestion Utilisateur (actif) -->
                <Button fx:id="btnUsers" text="👥 Gestion Utilisateur"
                        style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 14 18; -fx-alignment: CENTER_LEFT; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-border-color: rgba(255,255,255,0.3); -fx-border-width: 1; -fx-border-radius: 12;"
                        onAction="#switchView" maxWidth="1.7976931348623157E308"/>

                <!-- Gestion Cours -->
                <Button fx:id="btnCourses" text="📚 Gestion Cours"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.9); -fx-cursor: hand; -fx-padding: 12 18; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-background-radius: 10;"
                        onAction="#switchView" maxWidth="1.7976931348623157E308"/>

                <!-- Gestion Emploi -->
                <Button fx:id="btnEmploi" text="📅 Gestion Emploi"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.9); -fx-cursor: hand; -fx-padding: 12 18; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-background-radius: 10;"
                        onAction="#switchView" maxWidth="1.7976931348623157E308"/>

                <!-- Gestion Consultations -->
                <Button fx:id="btnConsults" text="📞 Gestion Consultations"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.9); -fx-cursor: hand; -fx-padding: 12 18; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-background-radius: 10;"
                        onAction="#switchView" maxWidth="1.7976931348623157E308"/>

                <!-- Sous-menu Consultations -->
                <HBox spacing="10" style="-fx-padding: 0 0 0 25;">
                    <children>
                        <Button fx:id="btnSuivie" text="• Suivie"
                                style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.7); -fx-cursor: hand; -fx-padding: 8 15; -fx-alignment: CENTER_LEFT; -fx-font-size: 13px; -fx-background-radius: 8;"
                                onAction="#switchView" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnTherapie" text="• Thérapie"
                                style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.7); -fx-cursor: hand; -fx-padding: 8 15; -fx-alignment: CENTER_LEFT; -fx-font-size: 13px; -fx-background-radius: 8;"
                                onAction="#switchView" HBox.hgrow="ALWAYS"/>
                    </children>
                </HBox>

                <!-- Gestion Evenements -->
                <Button fx:id="btnEvents" text="🎉 Gestion Evenements"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.9); -fx-cursor: hand; -fx-padding: 12 18; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-background-radius: 10;"
                        onAction="#switchView" maxWidth="1.7976931348623157E308"/>

                <!-- Gestion Jeux -->
                <Button fx:id="btnJeux" text="🎮 Gestion Jeux"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.9); -fx-cursor: hand; -fx-padding: 12 18; -fx-alignment: CENTER_LEFT; -fx-font-size: 14px; -fx-background-radius: 10;"
                        onAction="#switchView" maxWidth="1.7976931348623157E308"/>

            </VBox>

            <!-- ===== ESPACE FLEXIBLE ===== -->
            <VBox VBox.vgrow="ALWAYS" />

            <!-- ===== FOOTER AVEC CITATION ===== -->
            <VBox spacing="12" style="-fx-padding: 20 0 10 0;">
                <Label text="💡 Un espace pensé pour chaque autiste"
                       style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12px; -fx-font-style: italic; -fx-wrap-text: true;"
                       wrapText="true"/>
                <Label text="v1.0.0" style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 10px;"/>
            </VBox>

            <!-- ===== BOUTON DÉCONNEXION ===== -->
            <Button fx:id="btnLogout" text="🚪 Déconnexion"
                    style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 12; -fx-padding: 14 18; -fx-font-size: 15px; -fx-alignment: CENTER_LEFT; -fx-font-weight: bold;"
                    onAction="#handleLogout" maxWidth="1.7976931348623157E308"/>
        </VBox>
    </left>

    <!-- ===== CONTENU PRINCIPAL ===== -->
    <center>
        <VBox BorderPane.alignment="CENTER">
            <children>
                <!-- Header avec profil admin -->
                <HBox alignment="CENTER_RIGHT" prefHeight="90.0" style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 5, 0, 0, 2);">
                    <padding>
                        <Insets right="40.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #f8fafc; -fx-background-radius: 40px; -fx-padding: 10 25;">
                            <children>
                                <VBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Label fx:id="adminNameLabel" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Admin AutiCare" />
                                        <Label fx:id="adminRoleLabel" style="-fx-font-size: 12px; -fx-text-fill: #64748b;" text="Administrateur" />
                                    </children>
                                </VBox>
                                <Circle fx:id="adminAvatar" radius="28.0" style="-fx-fill: linear-gradient(to bottom right, #667eea, #764ba2); -fx-stroke: white; -fx-stroke-width: 2;" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <!-- Zone de contenu -->
                <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" style="-fx-background-color: #f5f7fb;">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="20.0" />
                    </padding>
                </StackPane>
            </children>
        </VBox>
    </center>
</BorderPane>