<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="25.0" styleClass="main-bg" stylesheets="@../styles.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auticare.controller.UserFxController">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <children>
        <!-- Header avec titre -->
        <VBox spacing="5.0">
            <children>
                <Label styleClass="page-title" text="Gestion des utilisateurs">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
                <Label styleClass="page-subtitle" text="Gérez les membres de la plateforme AutiCare" />
            </children>
        </VBox>

        <!-- Barre de recherche et bouton d'ajout -->
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="search-section">
            <children>
                <TextField fx:id="searchField" promptText="Rechercher un utilisateur par nom ou email..."
                           styleClass="search-field" HBox.hgrow="ALWAYS">
                    <font>
                        <Font size="14.0" />
                    </font>
                </TextField>
                <Button fx:id="btnAddUser" text="+ Ajouter un membre" styleClass="btn-add"
                        onAction="#showAddUserParams" />
            </children>
        </HBox>

        <!-- Filtres -->
        <HBox spacing="20.0" styleClass="filters-section">
            <children>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Label styleClass="filter-label" text="Rôle :" />
                        <ComboBox fx:id="roleFilter" prefWidth="160.0" promptText="Tous les rôles"
                                  styleClass="filter-combo" />
                    </children>
                </HBox>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Label styleClass="filter-label" text="Statut :" />
                        <ComboBox fx:id="statusFilter" prefWidth="160.0" promptText="Tous les statuts"
                                  styleClass="filter-combo" />
                    </children>
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="userCountLabel" styleClass="user-count-badge" text="14 utilisateurs" />
            </children>
        </HBox>

        <!-- Tableau des utilisateurs -->
        <VBox styleClass="table-container" VBox.vgrow="ALWAYS">
            <children>
                <TableView fx:id="userTable" VBox.vgrow="ALWAYS" styleClass="user-table">
                    <columns>
                        <TableColumn fx:id="colUser" prefWidth="350.0" text="UTILISATEUR" />
                        <TableColumn fx:id="colContact" prefWidth="300.0" text="CONTACT" />
                        <TableColumn fx:id="colRole" prefWidth="150.0" text="RÔLE" />
                        <TableColumn fx:id="colStatus" prefWidth="130.0" text="STATUT" />
                        <TableColumn fx:id="colActions" prefWidth="120.0" text="ACTIONS" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>