<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="750.0" prefWidth="1000.0" style="-fx-background-color: linear-gradient(to bottom right, #7B2FF7, #5F0FFF);"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auticare.controller.RegisterController">

    <children>
        <!-- Carte d'inscription -->
        <VBox alignment="CENTER" prefWidth="450.0" spacing="15.0"
              style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 10); -fx-padding: 30;"
              AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="275.0"
              AnchorPane.rightAnchor="275.0" AnchorPane.topAnchor="30.0">

            <!-- Logo -->
            <VBox alignment="CENTER" spacing="5">
                <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/logo.png" />
                    </image>
                </ImageView>
                <Label text="AutiCare" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #7B2FF7;" />
            </VBox>

            <!-- Titre -->
            <Label text="Créer un compte" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" />
            <Label text="Rejoignez la communauté AutiCare" style="-fx-font-size: 14px; -fx-text-fill: #64748B;" />

            <!-- Formulaire avec ScrollPane pour éviter le débordement -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                <content>
                    <VBox spacing="15.0" style="-fx-background-color: transparent; -fx-padding: 5 0 0 0;">

                        <!-- NOM COMPLET -->
                        <VBox spacing="3.0">
                            <Label text="NOM COMPLET" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748B;" />
                            <TextField fx:id="nameField" promptText="Votre nom"
                                       style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-padding: 12 15; -fx-font-size: 14px;" />
                            <Label fx:id="nameErrorLabel" text="Le nom est requis"
                                   style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 2 0 0 5;"
                                   visible="false" managed="false" />
                        </VBox>

                        <!-- EMAIL -->
                        <VBox spacing="3.0">
                            <Label text="EMAIL" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748B;" />
                            <TextField fx:id="emailField" promptText="nom@exemple.com"
                                       style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-padding: 12 15; -fx-font-size: 14px;" />
                            <Label fx:id="emailErrorLabel" text="Format d'email invalide"
                                   style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 2 0 0 5;"
                                   visible="false" managed="false" />
                        </VBox>

                        <!-- TÉLÉPHONE -->
                        <VBox spacing="3.0">
                            <Label text="TÉLÉPHONE" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748B;" />
                            <TextField fx:id="phoneField" promptText="+216 22 123 456"
                                       style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-padding: 12 15; -fx-font-size: 14px;" />
                            <Label fx:id="phoneErrorLabel" text="Le téléphone doit contenir 8 à 15 chiffres"
                                   style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 2 0 0 5;"
                                   visible="false" managed="false" />
                        </VBox>

                        <!-- MOT DE PASSE -->
                        <VBox spacing="3.0">
                            <Label text="MOT DE PASSE" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748B;" />
                            <PasswordField fx:id="passwordField" promptText="••••••••"
                                           style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-padding: 12 15; -fx-font-size: 14px;" />
                            <Label fx:id="passwordErrorLabel" text="Le mot de passe doit contenir au moins 6 caractères"
                                   style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 2 0 0 5;"
                                   visible="false" managed="false" />
                        </VBox>

                        <!-- CONFIRMER MOT DE PASSE -->
                        <VBox spacing="3.0">
                            <Label text="CONFIRMER MOT DE PASSE" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748B;" />
                            <PasswordField fx:id="confirmPasswordField" promptText="••••••••"
                                           style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-padding: 12 15; -fx-font-size: 14px;" />
                            <Label fx:id="confirmPasswordErrorLabel" text="Les mots de passe ne correspondent pas"
                                   style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 2 0 0 5;"
                                   visible="false" managed="false" />
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- Bouton d'inscription -->
            <Button fx:id="btnRegister" text="CRÉER MON COMPTE" maxWidth="1.7976931348623157E308"
                    style="-fx-background-color: linear-gradient(to right, #7B2FF7, #9F7AEA); -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 15 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(123,47,247,0.3), 10, 0, 0, 2);"
                    onAction="#handleRegister" />

            <!-- Lien vers connexion -->
            <HBox alignment="CENTER" spacing="5.0">
                <Label text="Déjà un compte ?" style="-fx-text-fill: #64748B;" />
                <Hyperlink onAction="#handleBackToLogin"
                           style="-fx-text-fill: #7B2FF7; -fx-font-weight: bold; -fx-border-color: transparent;"
                           text="Se connecter" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>