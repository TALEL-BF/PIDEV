<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: linear-gradient(to bottom right, #7B2FF7, #5F0FFF);"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auticare.controller.LoginController">

    <children>
        <!-- Carte de connexion -->
        <VBox alignment="CENTER" prefWidth="400.0" spacing="25.0"
              style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 10); -fx-padding: 40;"
              AnchorPane.bottomAnchor="100.0" AnchorPane.leftAnchor="300.0"
              AnchorPane.rightAnchor="300.0" AnchorPane.topAnchor="100.0">

            <!-- Logo -->
            <VBox alignment="CENTER" spacing="10">
                <ImageView fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/logo.png" />
                    </image>
                </ImageView>
                <Label text="AutiCare" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #7B2FF7;" />
                <Label text="Espace éducatif" style="-fx-font-size: 14px; -fx-text-fill: #94A3B8;" />
            </VBox>

            <!-- Titre -->
            <Label text="Connexion à votre espace" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" />

            <!-- Champ Email avec message d'erreur -->
            <VBox spacing="5.0">
                <Label text="EMAIL" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748B;" />
                <TextField fx:id="emailField" promptText="nom@exemple.com"
                           style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-padding: 12 15; -fx-font-size: 14px;" />
                <Label fx:id="emailErrorLabel" text="Email invalide"
                       style="-fx-text-fill: #EF4444; -fx-font-size: 12px; -fx-font-weight: bold;"
                       visible="false" managed="false" />
            </VBox>

            <!-- Champ Mot de passe avec message d'erreur -->
            <VBox spacing="5.0">
                <Label text="MOT DE PASSE" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748B;" />
                <PasswordField fx:id="passwordField" promptText="••••••••"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-padding: 12 15; -fx-font-size: 14px;" />
                <Label fx:id="passwordErrorLabel" text="Mot de passe requis"
                       style="-fx-text-fill: #EF4444; -fx-font-size: 12px; -fx-font-weight: bold;"
                       visible="false" managed="false" />
            </VBox>

            <!-- Bouton de connexion -->
            <Button fx:id="btnLogin" text="SE CONNECTER" maxWidth="1.7976931348623157E308"
                    style="-fx-background-color: linear-gradient(to right, #7B2FF7, #9F7AEA); -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 15 0; -fx-cursor: hand;"
                    onAction="#handleLogin" />

            <!-- Liens -->
            <VBox alignment="CENTER" spacing="10.0">
                <Hyperlink fx:id="forgotPasswordLink" onAction="#handleForgotPassword"
                           style="-fx-text-fill: #7B2FF7; -fx-font-size: 13px; -fx-border-color: transparent;"
                           text="Mot de passe oublié ?" />

                <HBox alignment="CENTER" spacing="5.0">
                    <Label text="Pas encore de compte ?" style="-fx-text-fill: #64748B;" />
                    <Hyperlink onAction="#handleRegister"
                               style="-fx-text-fill: #7B2FF7; -fx-font-weight: bold; -fx-border-color: transparent;"
                               text="CRÉER UN COMPTE ICI" />
                </HBox>
            </VBox>
        </VBox>
    </children>
</AnchorPane>