<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="750.0" prefWidth="1000.0"
            style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2);"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auticare.controller.LoginController">

    <children>
        <!-- Carte de connexion -->
        <VBox alignment="CENTER" prefWidth="400.0" spacing="25.0"
              style="-fx-background-color: white; -fx-background-radius: 30; -fx-padding: 40;"
              AnchorPane.bottomAnchor="100.0" AnchorPane.leftAnchor="300.0"
              AnchorPane.rightAnchor="300.0" AnchorPane.topAnchor="100.0">

            <effect>
                <DropShadow offsetX="0" offsetY="10" color="#00000040" radius="20" />
            </effect>

            <!-- Logo -->
            <VBox alignment="CENTER" spacing="10">
                <ImageView fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/logo.jpg" />
                    </image>
                </ImageView>
                <Label text="AutiCare"
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: linear-gradient(to right, #667eea, #764ba2); -fx-font-family: 'Poppins';" />
                <Label text="Espace éducatif"
                       style="-fx-font-size: 14px; -fx-text-fill: #64748B; -fx-font-family: 'Poppins';" />
            </VBox>

            <!-- Titre -->
            <Label text="Connexion à votre espace"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B; -fx-font-family: 'Poppins';" />

            <!-- Champ Email -->
            <VBox spacing="8.0" style="-fx-padding: 10 0 0 0;">
                <Label text="EMAIL"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-family: 'Poppins';" />
                <TextField fx:id="emailField" promptText="nom@exemple.com"
                           style="-fx-background-color: #F8FAFC; -fx-background-radius: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 15; -fx-padding: 15 20; -fx-font-size: 14px;" />
                <Label fx:id="emailErrorLabel" text="Email invalide"
                       style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold;"
                       visible="false" managed="false" />
            </VBox>

            <!-- Champ Mot de passe -->
            <VBox spacing="8.0">
                <Label text="MOT DE PASSE"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-family: 'Poppins';" />
                <PasswordField fx:id="passwordField" promptText="••••••••"
                               style="-fx-background-color: #F8FAFC; -fx-background-radius: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 15; -fx-padding: 15 20; -fx-font-size: 14px;" />
                <Label fx:id="passwordErrorLabel" text="Mot de passe requis"
                       style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold;"
                       visible="false" managed="false" />
            </VBox>

            <!-- Bouton de connexion -->
            <Button fx:id="btnLogin" text="SE CONNECTER" maxWidth="1.7976931348623157E308"
                    style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 15 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, #667eea66, 10, 0, 0, 2);"
                    onAction="#handleLogin" />

            <!-- Liens -->
            <VBox alignment="CENTER" spacing="10.0">
                <Hyperlink fx:id="forgotPasswordLink" onAction="#handleForgotPassword"
                           style="-fx-text-fill: #667eea; -fx-font-size: 13px; -fx-border-color: transparent; -fx-font-family: 'Poppins';"
                           text="Mot de passe oublié ?" />

                <HBox alignment="CENTER" spacing="5.0">
                    <Label text="Pas encore de compte ?"
                           style="-fx-text-fill: #64748B; -fx-font-family: 'Poppins';" />
                    <Hyperlink onAction="#handleRegister"
                               style="-fx-text-fill: #764ba2; -fx-font-weight: bold; -fx-border-color: transparent; -fx-font-family: 'Poppins';"
                               text="CRÉER UN COMPTE ICI" />
                </HBox>
            </VBox>
        </VBox>
    </children>
</AnchorPane>