<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.RapportIAController"
            stylesheets="@styles/app.css"
            prefWidth="1540" prefHeight="850"
            style="-fx-background-color: #f8fafc;">

    <!-- ========== SIDEBAR ========== -->
    <left>
        <VBox prefWidth="200.0"
              minWidth="200.0"
              maxWidth="200.0"
              spacing="12"
              style="-fx-background-color: linear-gradient(to bottom, #7B2FF7, #5F0FFF); -fx-padding:15;">

            <!-- Logo + Titre -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ImageView fitWidth="45" fitHeight="45" preserveRatio="true">
                    <image>
                        <Image url="@assets/logo.png"/>
                    </image>
                </ImageView>
                <VBox>
                    <Label text="AutiCare" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 900;"/>
                    <Label text="Plateforme éducative" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 11px;"/>
                </VBox>
            </HBox>

            <!-- Connecté en tant qu'étudiant -->
            <VBox spacing="4" style="-fx-padding: 5 0 0 0;">
                <Label text="Connecté en tant que" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
                <Label text="👤 Étudiant"
                       style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white;
                      -fx-padding: 6 15; -fx-background-radius: 30; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            </VBox>

            <Separator style="-fx-background-color: rgba(255,255,255,0.2); -fx-padding: 5 0;"/>

            <!-- Menu -->
            <Button text="📚 Nos cours"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-size: 12px; -fx-cursor: hand;"/>

            <Button text="🗓️Emploi du temps"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-size: 12px; -fx-cursor: hand;"/>

            <Button text=" 🩺 Nos  consultations"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-size: 12px; -fx-cursor: hand; -fx-wrap-text: true;"/>

            <!-- GESTION DES ÉVÉNEMENTS -->
            <Button text="🎉 Nos événements"
                    style="-fx-background-color: rgba(255,255,255,0.25); -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand;"/>

            <Button text=" 🎮 Nos jeux educatif"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-size: 12px; -fx-cursor: hand;"/>

            <VBox VBox.vgrow="ALWAYS" />

            <!-- Déconnexion -->
            <Button text="Déconnexion"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-size: 13px; -fx-cursor: hand;"/>

            <Label text="💡 Un espace pensé pour chaque autiste"
                   wrapText="true"
                   style="-fx-text-fill: #C4B5FD; -fx-font-size: 12px; -fx-font-style: italic; -fx-padding: 10 0 0 0;"/>
        </VBox>
    </left>

    <!-- ========== MAIN CONTENT ========== -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent;">
            <VBox spacing="30" style="-fx-padding: 30; -fx-background-color: white;">

                <!-- Titre -->
                <Label text="🤖 Assistant IA - Générateur de Rapports"
                       style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #8b5cf6;"/>

                <!-- Zone de saisie -->
                <VBox spacing="10">
                    <Label text="Sujet du rapport :" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <HBox spacing="15">
                        <TextField fx:id="sujetField" promptText="Ex: stress, autisme, relaxation..."
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-padding: 12; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;"/>
                        <Button fx:id="genererBtn" text="Générer le rapport"
                                style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 12 25; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <!-- Zone d'affichage du rapport -->
                <VBox spacing="10" VBox.vgrow="ALWAYS">
                    <!-- ✅ NOUVEAU : Barre d'outils avec bouton PDF -->
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Label text="Rapport généré :" style="-fx-font-size: 16px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="pdfButton"
                                text="📄 Télécharger PDF"
                                disable="true"
                                style="-fx-background-color: #ec4899;
                                       -fx-text-fill: white;
                                       -fx-font-weight: bold;
                                       -fx-background-radius: 20;
                                       -fx-padding: 8 20;
                                       -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(236,72,153,0.3), 10, 0, 0, 3);"/>
                    </HBox>

                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                style="-fx-background-color: #f8fafc; -fx-background-radius: 10;">
                        <TextArea fx:id="rapportArea"
                                  editable="false"
                                  wrapText="true"
                                  style="-fx-font-family: monospace; -fx-font-size: 14px; -fx-padding: 15; -fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 10;"
                                  prefHeight="400"/>
                    </ScrollPane>
                </VBox>

                <!-- Bouton retour -->
                <HBox alignment="CENTER_LEFT">
                    <Button fx:id="backButton" text="← Retour au tableau de bord"
                            onAction="#goBackToShowEvent"
                            style="-fx-background-color: transparent; -fx-text-fill: #8b5cf6; -fx-font-weight: bold; -fx-underline: true; -fx-cursor: hand;"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>