<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.EventDetailsController"
            stylesheets="@styles/app.css"
            prefWidth="1520" prefHeight="850"
            style="-fx-background-color: #f8fafc;">

    <!-- ========== SIDEBAR ========== -->
    <left>
        <VBox prefWidth="220.0"
              minWidth="220.0"
              maxWidth="220.0"
              spacing="15"
              style="-fx-background-color: linear-gradient(to bottom, #7B2FF7, #5F0FFF); -fx-padding:20;">

            <!-- Logo + Titre -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <ImageView fitWidth="40" fitHeight="40" preserveRatio="true">
                    <image>
                        <Image url="@assets/logo.png"/>
                    </image>
                </ImageView>
                <VBox>
                    <Label text="AutiCare" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 900;"/>
                    <Label text="Plateforme éducative" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 12px;"/>
                </VBox>
            </HBox>

            <!-- Connecté en tant qu'étudiant -->
            <VBox spacing="5" style="-fx-padding: 5 0 0 0;">
                <Label text="Connecté en tant que" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 13px;"/>
                <Label text="👤 Étudiant"
                       style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white;
                      -fx-padding: 8 18; -fx-background-radius: 30; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            </VBox>

            <Separator style="-fx-background-color: rgba(255,255,255,0.2); -fx-padding: 5 0;"/>

            <!-- Menu -->
            <Button text="📚 Nos cours"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-size: 12px; -fx-cursor: hand;"/>

            <Button text="🗓️Emploi du temps"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-size: 12px; -fx-cursor: hand;"/>

            <Button text=" 🩺 Nos  consultations"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-size: 12px; -fx-cursor: hand; -fx-wrap-text: true;"/>

            <Button text="🎉 Nos événements"
                    style="-fx-background-color: rgba(255,255,255,0.25); -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand;"/>

            <Button text=" 🎮 Nos jeux educatif"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-size: 12px; -fx-cursor: hand;"/>

            <VBox VBox.vgrow="ALWAYS" />

            <!-- Déconnexion -->
            <Button text="Déconnexion"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-size: 13px; -fx-cursor: hand;"/>

            <Label text="💡 Un espace pensé pour chaque autiste"
                   wrapText="true"
                   style="-fx-text-fill: #C4B5FD; -fx-font-size: 12px; -fx-font-style: italic; -fx-padding: 10 0 0 0;"/>
        </VBox>
    </left>

    <!-- ========== MAIN CONTENT ========== -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="25" style="-fx-padding: 25;">

                <!-- ========== HERO BANNER ========== -->
                <StackPane fx:id="heroStackPane"
                           prefHeight="220"
                           style="-fx-background-radius: 25; -fx-border-radius: 25; -fx-overflow: hidden;
                                  -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.3), 15, 0, 0, 5);"
                           HBox.hgrow="ALWAYS">

                    <ImageView fx:id="heroImage"
                               preserveRatio="false"
                               fitWidth="1250"
                               fitHeight="250"
                               smooth="true">
                        <image>
                            <Image url="@assets/jeux (6).jpg"/>
                        </image>
                    </ImageView>
                    <Region style="-fx-background-color: linear-gradient(to right, rgba(139,92,246,0.3), rgba(107,70,193,0.3)); -fx-background-radius: 25;"/>

                    <Rectangle width="800" height="140" arcWidth="30" arcHeight="30"
                               fill="rgba(255,255,255,0.3)"
                               style="-fx-arc-width: 30; -fx-arc-height: 30;"/>

                    <VBox alignment="CENTER" spacing="8">
                        <Label text="🌸Entrez dans l’univers de l’événement 🌸"
                               style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;
                                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 5, 0, 2, 2);"/>
                        <Label text="Vivez chaque instant et laissez-vous émerveiller par nos activités uniques"
                               style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 600;
                                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 3, 0, 1, 1);"/>
                    </VBox>
                </StackPane>

                <!-- ========== BACK BUTTON ========== -->
                <HBox alignment="CENTER_LEFT">
                    <Button fx:id="backButton"
                            text="← Retour aux événements"
                            onAction="#goBackToShowEvent"
                            style="-fx-background-color: #f0f0f0;
                                   -fx-text-fill: #4a5568;
                                   -fx-background-radius: 30;
                                   -fx-padding: 8 20;
                                   -fx-font-size: 14px;
                                   -fx-font-weight: bold;
                                   -fx-cursor: hand;
                                   -fx-border-color: #e2e8f0;
                                   -fx-border-radius: 30;
                                   -fx-border-width: 1;"/>
                </HBox>

                <!-- ========== EVENT TITLE ========== -->
                <Label fx:id="eventTitleLabel" text="Titre de l'Événement"
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #8b5cf6; -fx-padding: 0 0 0 5;"/>

                <!-- ========== GRAND CADRE ========== -->
                <VBox spacing="25" style="-fx-background-color: #f5f0ff; -fx-background-radius: 20; -fx-padding: 25; -fx-border-color: #c4b5fd; -fx-border-width: 3; -fx-border-radius: 10; -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.1), 8, 0, 0, 3);">

                    <!-- ========== CONTENU PRINCIPAL ========== -->
                    <HBox spacing="25">

                        <!-- ========== COLONNE GAUCHE ========== -->
                        <VBox spacing="20" style="-fx-pref-width: 600;">

                            <!-- IMAGE DE L'ÉVÉNEMENT -->
                            <StackPane style="-fx-background-color: transparent; -fx-padding: 0;">
                                <ImageView fx:id="eventImageView" fitWidth="580" fitHeight="300" preserveRatio="true"
                                           style="-fx-background-radius: 30; -fx-border-radius: 30;">
                                    <image><Image url="@assets/event-default.jpg"/></image>
                                </ImageView>
                            </StackPane>

                            <!-- Description Box -->
                            <VBox spacing="5"
                                  style="-fx-background-color: #f0e8ff;
                                         -fx-background-radius: 20;
                                         -fx-padding: 15;
                                         -fx-border-color: #c4b5fd;
                                         -fx-border-width: 2;
                                         -fx-border-radius: 20;">

                                <Label text="📝 Description"
                                       style="-fx-font-size: 18px;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: #8b5cf6;
                                              -fx-padding: 0 0 2 0;"/>

                                <TextArea fx:id="descriptionArea"
                                          wrapText="true"
                                          editable="false"
                                          prefRowCount="6"
                                          style="-fx-font-size: 15px;
                                                 -fx-text-fill: #4a5568;
                                                 -fx-control-inner-background: transparent;
                                                 -fx-background-color: transparent;
                                                 -fx-border-color: transparent;
                                                 -fx-padding: 0;"/>
                            </VBox>
                        </VBox>

                        <!-- ========== COLONNE DROITE ========== -->
                        <VBox spacing="20" style="-fx-pref-width: 350;">

                            <!-- Informations Card -->
                            <VBox spacing="15" style="-fx-background-color: #f0e8ff; -fx-background-radius: 20; -fx-padding: 20; -fx-border-color: #c4b5fd; -fx-border-width: 2; -fx-border-radius: 20;"
                                  prefWidth="700">

                                <Label text="📋 Informations" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #8b5cf6;"/>

                                <GridPane hgap="15" vgap="12">
                                    <!-- Date -->
                                    <ImageView fitWidth="42" fitHeight="42" preserveRatio="true" GridPane.rowIndex="0" GridPane.columnIndex="0">
                                        <image><Image url="@assets/calender.png"/></image>
                                    </ImageView>
                                    <VBox GridPane.rowIndex="0" GridPane.columnIndex="1">
                                        <Label text="Date" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                                        <Label fx:id="dateLabel" text="15 Mars 2026" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #2d3748;"/>
                                    </VBox>

                                    <!-- Heure -->
                                    <ImageView fitWidth="42" fitHeight="42" preserveRatio="true" GridPane.rowIndex="1" GridPane.columnIndex="0">
                                        <image><Image url="@assets/clock.png"/></image>
                                    </ImageView>
                                    <VBox GridPane.rowIndex="1" GridPane.columnIndex="1">
                                        <Label text="Horaire" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                                        <Label fx:id="timeLabel" text="14:30 - 16:30" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #2d3748;"/>
                                    </VBox>

                                    <!-- Lieu -->
                                    <ImageView fitWidth="42" fitHeight="42" preserveRatio="true" GridPane.rowIndex="2" GridPane.columnIndex="0">
                                        <image><Image url="@assets/lieu1.png"/></image>
                                    </ImageView>
                                    <VBox GridPane.rowIndex="2" GridPane.columnIndex="1">
                                        <Label text="Lieu" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                                        <Label fx:id="locationLabel" text="Espace Culturel, Tunis" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #2d3748;"/>
                                    </VBox>

                                    <!-- Type -->
                                    <ImageView fitWidth="42" fitHeight="42" preserveRatio="true" GridPane.rowIndex="3" GridPane.columnIndex="0">
                                        <image><Image url="@assets/yeno.png"/></image>
                                    </ImageView>
                                    <VBox GridPane.rowIndex="3" GridPane.columnIndex="1">
                                        <Label text="Type" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                                        <Label fx:id="typeLabel" text="Atelier" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #8b5cf6;"/>
                                    </VBox>
                                </GridPane>
                            </VBox>

                            <!-- À propos Card -->
                            <VBox spacing="10" style="-fx-background-color: #f0e8ff; -fx-background-radius: 20; -fx-padding: 20; -fx-border-color: #c4b5fd; -fx-border-width: 2; -fx-border-radius: 20;" VBox.vgrow="ALWAYS">
                                <Label text="👤 À propos" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #8b5cf6;"/>
                                <Label fx:id="aboutLabel" wrapText="true"
                                       text="Association AutiCare organise cet événement pour offrir un espace adapté et bienveillant. Notre équipe est formée pour accueillir les personnes autistes et leurs familles dans les meilleures conditions possibles."
                                       style="-fx-text-fill: #4a5568; -fx-font-size: 14px;" VBox.vgrow="ALWAYS"/>
                            </VBox>

                            <!-- Bouton Rapport IA -->
                            <Button fx:id="rapportIABtn" text="🤖 Rapport IA"
                                    style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-size: 16px;
                                           -fx-font-weight: 700; -fx-background-radius: 40; -fx-padding: 12 0;
                                           -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.3), 8, 0, 0, 2);
                                           -fx-max-width: Infinity;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ========== BOUTON PARTICIPER ========== -->
                <HBox alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                    <Button fx:id="registerBtn" text=" 📢 Participer"
                            style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-size: 18px;
                                   -fx-font-weight: 700; -fx-background-radius: 40; -fx-padding: 10 40;
                                   -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.3), 8, 0, 0, 2);"/>
                </HBox>

                <!-- Espacement -->
                <Region style="-fx-padding: 10 0 0 0;"/>

                <!-- ========== SPONSORS CARD ========== -->
                <VBox spacing="15"
                      alignment="CENTER"
                      style="-fx-background-color: linear-gradient(from 0% 100% to 0% 0%,
                                                   #e9d5ff 0%,
                                                   #ede9fe 60%,
                                                   #f8f7ff 100%);
                             -fx-padding: 10 0 30 0;">

                    <Label text="🤝 Sponsors de l'événement"
                           style="-fx-font-size: 20px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #a78bfa;
                                  -fx-padding: 0 0 3 0;"/>

                    <FlowPane fx:id="sponsorsFlowPane"
                              hgap="25"
                              vgap="15"
                              alignment="CENTER"/>
                </VBox>

                <!-- ========== FEEDBACKS CARD ========== -->
                <VBox spacing="20" style="-fx-background-color: #f5f0ff; -fx-background-radius: 20; -fx-padding: 25; -fx-border-color: #c4b5fd; -fx-border-width: 1; -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(196,181,253,0.2), 8, 0, 0, 3);">

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <ImageView fitWidth="35" fitHeight="35" preserveRatio="true">
                            <image>
                                <Image url="@assets/comment.png"/>
                            </image>
                        </ImageView>
                        <Label text="Avis des participants"
                               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #8b5cf6;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="4.8 ⭐"
                               style="-fx-background-color: #bbf7d0;
                                      -fx-text-fill: #15803d;
                                      -fx-padding: 5 15;
                                      -fx-background-radius: 20;
                                      -fx-font-weight: bold;
                                      -fx-border-color: #4ade80;
                                      -fx-border-width: 1;
                                      -fx-border-radius: 20;"/>
                    </HBox>

                    <!-- Feedbacks en grille 2x2 -->
                    <GridPane hgap="20" vgap="20" alignment="CENTER">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50" halignment="CENTER"/>
                            <ColumnConstraints percentWidth="50" halignment="CENTER"/>
                        </columnConstraints>

                        <!-- Feedback 1 -->
                        <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #e5dbff; -fx-border-width: 1; -fx-border-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 5, 0, 0, 2);"
                              GridPane.rowIndex="0" GridPane.columnIndex="0">
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <ImageView fitWidth="50" fitHeight="50" preserveRatio="true" style="-fx-background-radius: 25; -fx-border-radius: 25;">
                                    <image><Image url="@assets/user1.jpg"/></image>
                                </ImageView>
                                <VBox>
                                    <Label text="Marie Dubois" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2d3748;"/>
                                    <Label text="Participante" style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
                                </VBox>
                            </HBox>
                            <Label text="⭐⭐⭐⭐⭐" style="-fx-text-fill: #f59e0b; -fx-font-size: 14px;"/>
                            <Label text="Ambiance calme et accueillante, parfait pour moi !" wrapText="true" style="-fx-text-fill: #4a5568; -fx-font-size: 13px;"/>
                        </VBox>

                        <!-- Feedback 2 -->
                        <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #e5dbff; -fx-border-width: 1; -fx-border-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 5, 0, 0, 2);"
                              GridPane.rowIndex="0" GridPane.columnIndex="1">
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <ImageView fitWidth="50" fitHeight="50" preserveRatio="true" style="-fx-background-radius: 25; -fx-border-radius: 25;">
                                    <image><Image url="@assets/user2.jpg"/></image>
                                </ImageView>
                                <VBox>
                                    <Label text="Thomas Martin" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2d3748;"/>
                                    <Label text="Parent" style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
                                </VBox>
                            </HBox>
                            <Label text="⭐⭐⭐⭐" style="-fx-text-fill: #f59e0b; -fx-font-size: 14px;"/>
                            <Label text="Très belle expérience, je recommande vivement cet atelier." wrapText="true" style="-fx-text-fill: #4a5568; -fx-font-size: 13px;"/>
                        </VBox>

                        <!-- Feedback 3 -->
                        <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #e5dbff; -fx-border-width: 1; -fx-border-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 5, 0, 0, 2);"
                              GridPane.rowIndex="1" GridPane.columnIndex="0">
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <ImageView fitWidth="50" fitHeight="50" preserveRatio="true" style="-fx-background-radius: 25; -fx-border-radius: 25;">
                                    <image><Image url="@assets/user3.jpg"/></image>
                                </ImageView>
                                <VBox>
                                    <Label text="Sophie Bernard" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2d3748;"/>
                                    <Label text="Éducatrice" style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
                                </VBox>
                            </HBox>
                            <Label text="⭐⭐⭐⭐⭐" style="-fx-text-fill: #f59e0b; -fx-font-size: 14px;"/>
                            <Label text="L'équipe est super attentionnée, espace très agréable." wrapText="true" style="-fx-text-fill: #4a5568; -fx-font-size: 13px;"/>
                        </VBox>

                        <!-- Feedback 4 -->
                        <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #e5dbff; -fx-border-width: 1; -fx-border-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 5, 0, 0, 2);"
                              GridPane.rowIndex="1" GridPane.columnIndex="1">
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <ImageView fitWidth="50" fitHeight="50" preserveRatio="true" style="-fx-background-radius: 25; -fx-border-radius: 25;">
                                    <image><Image url="@assets/user4.jpg"/></image>
                                </ImageView>
                                <VBox>
                                    <Label text="Lucas Petit" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2d3748;"/>
                                    <Label text="Participant" style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
                                </VBox>
                            </HBox>
                            <Label text="⭐⭐⭐⭐" style="-fx-text-fill: #f59e0b; -fx-font-size: 14px;"/>
                            <Label text="Atelier très intéressant, j'ai appris beaucoup de choses." wrapText="true" style="-fx-text-fill: #4a5568; -fx-font-size: 13px;"/>
                        </VBox>
                    </GridPane>

                    <Button text="Voir tous les avis" style="-fx-background-color: transparent; -fx-text-fill: #8b5cf6; -fx-font-weight: bold; -fx-border-color: #8b5cf6; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 10; -fx-cursor: hand; -fx-max-width: 200;" alignment="CENTER"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>