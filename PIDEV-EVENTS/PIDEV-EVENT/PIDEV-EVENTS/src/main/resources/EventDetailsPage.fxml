<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.shape.Rectangle?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.EventDetailsController"
            stylesheets="@styles/app.css"
            prefWidth="1300" prefHeight="650"
            style="-fx-background-color: #ede9fe;">

    <!-- ========== SIDEBAR ========== -->
    <left>
        <VBox prefWidth="200.0"
              minWidth="200.0"
              maxWidth="200.0"
              spacing="12"
              style="-fx-background-color: linear-gradient(to bottom, #7B2FF7, #5F0FFF); -fx-padding:15;">

            <!-- Logo + Titre -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ImageView fitWidth="45" fitHeight="45" preserveRatio="true">
                    <image>
                        <Image url="@assets/logo.png"/>
                    </image>
                </ImageView>
                <VBox>
                    <Label text="AutiCare" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 900;"/>
                    <Label text="Plateforme éducative" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 11px;"/>
                </VBox>
            </HBox>

            <!-- Connecté en tant qu'étudiant -->
            <VBox spacing="4" style="-fx-padding: 5 0 0 0;">
                <Label text="Connecté en tant que" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;"/>
                <Label text="👤 Étudiant"
                       style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white;
                      -fx-padding: 6 15; -fx-background-radius: 30; -fx-font-weight: bold; -fx-font-size: 13px;"/>
            </VBox>

            <Separator style="-fx-background-color: rgba(255,255,255,0.2); -fx-padding: 5 0;"/>

            <!-- Menu -->
            <Button text="📚 Nos cours"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-size: 12px; -fx-cursor: hand;"/>

            <Button text="🗓️Emploi du temps"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-size: 12px; -fx-cursor: hand;"/>

            <Button text=" 🩺 Nos  consultations"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-size: 12px; -fx-cursor: hand; -fx-wrap-text: true;"/>

            <!-- GESTION DES ÉVÉNEMENTS -->
            <Button text="🎉 Nos événements"
                    style="-fx-background-color: rgba(255,255,255,0.25); -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand;"/>

            <Button text=" 🎮 Nos jeux educatif"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-size: 12px; -fx-cursor: hand;"/>

            <VBox VBox.vgrow="ALWAYS" />

            <!-- Déconnexion -->
            <Button text="Déconnexion"
                    style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white;
                   -fx-alignment: CENTER_LEFT; -fx-padding: 6 12; -fx-background-radius: 10;
                   -fx-font-size: 13px; -fx-cursor: hand;"/>

            <Label text="💡 Un espace pensé pour chaque autiste"
                   wrapText="true"
                   style="-fx-text-fill: #C4B5FD; -fx-font-size: 12px; -fx-font-style: italic; -fx-padding: 10 0 0 0;"/>
        </VBox>
    </left>

    <!-- ========== MAIN CONTENT ========== -->
    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <HBox alignment="CENTER_LEFT" spacing="0">  <!-- HBox pour décaler à gauche -->
                <!-- Espace vide à gauche réduit -->
                  <Region prefWidth="10" />

                  <VBox spacing="20" style="-fx-padding: 15 15 15 0; -fx-background-color: transparent;" prefWidth="1100">

                      <!-- ========== HERO BANNER ========== -->
                    <StackPane fx:id="heroStackPane"
                               prefHeight="220"
                               style="-fx-background-radius: 25; -fx-border-radius: 25; -fx-overflow: hidden;
                                  -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.3), 15, 0, 0, 5);"
                               HBox.hgrow="ALWAYS">

                        <ImageView fx:id="heroImage"
                                   preserveRatio="false"
                                   fitWidth="1250"
                                   fitHeight="250"
                                   smooth="true">
                            <image>
                                <Image url="@assets/jeux (6).jpg"/>
                            </image>
                        </ImageView>
                        <!-- Overlay violet semi-transparent -->
                        <Region style="-fx-background-color: linear-gradient(to right, rgba(139,92,246,0.3), rgba(107,70,193,0.3)); -fx-background-radius: 25;"/>

                        <Rectangle width="800" height="140" arcWidth="30" arcHeight="30"
                                   fill="rgba(255,255,255,0.3)"
                                   style="-fx-arc-width: 30; -fx-arc-height: 30;"/>

                        <VBox alignment="CENTER" spacing="8">
                            <Label text="🌸 Bienvenue à notre espace 🌸"
                                   style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;
                                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 5, 0, 2, 2);"/>
                            <Label text="Découvrez nos activités adaptées et bienveillantes"
                                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 600;
                                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 3, 0, 1, 1);"/>
                        </VBox>
                    </StackPane>

                    <!-- ========== BACK BUTTON ========== -->
                    <HBox alignment="CENTER_LEFT">
                        <Button fx:id="backButton"
                                text="← Retour aux événements"
                                onAction="#goBackToShowEvent"
                                style="-fx-background-color: #f0f0f0;
                                       -fx-text-fill: #4a5568;
                                       -fx-background-radius: 20;
                                       -fx-padding: 6 16;
                                       -fx-font-size: 12px;
                                       -fx-font-weight: bold;
                                       -fx-cursor: hand;
                                       -fx-border-color: #e2e8f0;
                                       -fx-border-radius: 20;
                                       -fx-border-width: 1;"/>
                    </HBox>

                    <!-- ========== TITRE ========== -->
                    <Label fx:id="eventTitleLabel"
                           text="Titre de l'Événement"
                           style="-fx-font-size: 26px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #7c3aed;
                                  -fx-padding: 5 0 5 0;"
                           maxWidth="Infinity" alignment="CENTER_LEFT"/>

                    <!-- ========== GRAND CADRE DÉCALÉ À GAUCHE ========== -->
                    <VBox spacing="18"
                          style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20;
                                 -fx-border-color: #c4b5fd; -fx-border-width: 2; -fx-border-radius: 20;
                                 -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.2), 15, 0, 0, 5);">

                        <!-- ========== RANGÉE 1: IMAGE + INFOS ========== -->
                        <HBox spacing="15" alignment="TOP_LEFT">

                            <!-- IMAGE (480px) - plus grande -->
                            <StackPane prefWidth="480" maxWidth="480" alignment="TOP_LEFT">
                                <ImageView fx:id="eventImageView" fitWidth="460" fitHeight="250" preserveRatio="true"
                                           style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 1);">
                                    <image><Image url="@assets/event-default.jpg"/></image>
                                </ImageView>
                            </StackPane>

                            <!-- INFORMATIONS (480px) - plus grande -->
                            <VBox spacing="10" prefWidth="480" maxWidth="480" minHeight="250" maxHeight="250"
                                  style="-fx-background-color: #f3e8ff; -fx-background-radius: 15; -fx-padding: 16;
                                         -fx-border-color: #d8b4fe; -fx-border-width: 1.5; -fx-border-radius: 15;
                                         -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.1), 5, 0, 0, 2);"
                                  alignment="TOP_LEFT">

                                <Label text="📋 Informations"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;"
                                       alignment="CENTER_LEFT"/>

                                <GridPane hgap="10" vgap="8" alignment="TOP_LEFT">
                                    <!-- Date -->
                                    <ImageView fitWidth="20" fitHeight="20" preserveRatio="true" GridPane.rowIndex="0" GridPane.columnIndex="0">
                                        <image><Image url="@assets/calender.png"/></image>
                                    </ImageView>
                                    <VBox spacing="1" GridPane.rowIndex="0" GridPane.columnIndex="1" alignment="TOP_LEFT">
                                        <Label text="Date" style="-fx-font-size: 10px; -fx-text-fill: #6b4e8a;" alignment="CENTER_LEFT"/>
                                        <Label fx:id="dateLabel" text="15 Mars 2026" style="-fx-font-size: 14px; -fx-font-weight: bold;" alignment="CENTER_LEFT"/>
                                    </VBox>

                                    <!-- Heure -->
                                    <ImageView fitWidth="20" fitHeight="20" preserveRatio="true" GridPane.rowIndex="1" GridPane.columnIndex="0">
                                        <image><Image url="@assets/clock.png"/></image>
                                    </ImageView>
                                    <VBox spacing="1" GridPane.rowIndex="1" GridPane.columnIndex="1" alignment="TOP_LEFT">
                                        <Label text="Horaire" style="-fx-font-size: 10px; -fx-text-fill: #6b4e8a;" alignment="CENTER_LEFT"/>
                                        <Label fx:id="timeLabel" text="14:30 - 16:30" style="-fx-font-size: 14px; -fx-font-weight: bold;" alignment="CENTER_LEFT"/>
                                    </VBox>

                                    <!-- Lieu -->
                                    <ImageView fitWidth="20" fitHeight="20" preserveRatio="true" GridPane.rowIndex="2" GridPane.columnIndex="0">
                                        <image><Image url="@assets/lieu1.png"/></image>
                                    </ImageView>
                                    <VBox spacing="1" GridPane.rowIndex="2" GridPane.columnIndex="1" alignment="TOP_LEFT">
                                        <Label text="Lieu" style="-fx-font-size: 10px; -fx-text-fill: #6b4e8a;" alignment="CENTER_LEFT"/>
                                        <Label fx:id="locationLabel" text="Espace Culturel" style="-fx-font-size: 14px; -fx-font-weight: bold;" alignment="CENTER_LEFT"/>
                                    </VBox>

                                    <!-- Type -->
                                    <ImageView fitWidth="20" fitHeight="20" preserveRatio="true" GridPane.rowIndex="3" GridPane.columnIndex="0">
                                        <image><Image url="@assets/yeno.png"/></image>
                                    </ImageView>
                                    <VBox spacing="1" GridPane.rowIndex="3" GridPane.columnIndex="1" alignment="TOP_LEFT">
                                        <Label text="Type" style="-fx-font-size: 10px; -fx-text-fill: #6b4e8a;" alignment="CENTER_LEFT"/>
                                        <Label fx:id="typeLabel" text="Atelier" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;" alignment="CENTER_LEFT"/>
                                    </VBox>
                                </GridPane>
                            </VBox>
                        </HBox>

                        <!-- ========== RANGÉE 2: DESCRIPTION + PARTICIPANTS/RAPPORT ========== -->
                        <HBox spacing="15" alignment="TOP_LEFT">

                            <!-- DESCRIPTION (480px) - plus grande -->
                            <VBox spacing="10" prefWidth="480" maxWidth="480" minHeight="270" maxHeight="270"
                                  style="-fx-background-color: #f3e8ff; -fx-background-radius: 15; -fx-padding: 16;
                                         -fx-border-color: #d8b4fe; -fx-border-width: 1.5; -fx-border-radius: 15;
                                         -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.1), 5, 0, 0, 2);"
                                  alignment="TOP_LEFT">

                                <Label text="📝 Description"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;"
                                       alignment="CENTER_LEFT"/>

                                <TextArea fx:id="descriptionArea"
                                          wrapText="true"
                                          editable="false"
                                          prefRowCount="4"
                                          style="-fx-font-size: 13px; -fx-background-color: white;
                                                 -fx-border-color: #e9d5ff; -fx-border-radius: 10;
                                                 -fx-background-radius: 10; -fx-padding: 8;"/>

                                <FlowPane fx:id="tagsContainer" hgap="6" vgap="4" alignment="TOP_LEFT">
                                    <Label text="#Bien-être" style="-fx-background-color: #ede9fe; -fx-padding: 4 10; -fx-background-radius: 15; -fx-font-size: 11px; -fx-text-fill: #7c3aed;"/>
                                    <Label text="#Atelier" style="-fx-background-color: #ede9fe; -fx-padding: 4 10; -fx-background-radius: 15; -fx-font-size: 11px; -fx-text-fill: #7c3aed;"/>
                                    <Label text="#Groupe" style="-fx-background-color: #ede9fe; -fx-padding: 4 10; -fx-background-radius: 15; -fx-font-size: 11px; -fx-text-fill: #7c3aed;"/>
                                    <Label text="#Écoute" style="-fx-background-color: #ede9fe; -fx-padding: 4 10; -fx-background-radius: 15; -fx-font-size: 11px; -fx-text-fill: #7c3aed;"/>
                                </FlowPane>
                            </VBox>

                            <!-- COLONNE DROITE: PARTICIPANTS (190px) + RAPPORT IA (80px) = 270px -->
                            <VBox spacing="8" prefWidth="480" maxWidth="480" minHeight="270" maxHeight="270" alignment="TOP_LEFT">

                                <!-- PARTICIPANTS (190px) - plus grand -->
                                <VBox spacing="8" prefWidth="480" maxWidth="480" minHeight="190" maxHeight="190"
                                      style="-fx-background-color: #f3e8ff; -fx-background-radius: 15; -fx-padding: 16;
                                             -fx-border-color: #d8b4fe; -fx-border-width: 1.5; -fx-border-radius: 15;
                                             -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.1), 5, 0, 0, 2);"
                                      alignment="TOP_LEFT">

                                    <Label text="👥 Participants"
                                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;"
                                           alignment="CENTER_LEFT"/>

                                    <HBox alignment="CENTER_LEFT" spacing="20">
                                        <VBox alignment="CENTER_LEFT" spacing="2">
                                            <Label fx:id="inscritsCount" text="4" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;" alignment="CENTER_LEFT"/>
                                            <Label text="Inscrits" style="-fx-font-size: 11px; -fx-text-fill: #6b4e8a; -fx-font-weight: 600;" alignment="CENTER_LEFT"/>
                                        </VBox>
                                        <Label text="/" style="-fx-font-size: 28px; -fx-text-fill: #d8c9ff; -fx-font-weight: 300;"/>
                                        <VBox alignment="CENTER_LEFT" spacing="2">
                                            <Label fx:id="maxParticipantsLabel" text="11" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #6b4e8a;" alignment="CENTER_LEFT"/>
                                            <Label text="Places" style="-fx-font-size: 11px; -fx-text-fill: #6b4e8a; -fx-font-weight: 600;" alignment="CENTER_LEFT"/>
                                        </VBox>
                                    </HBox>

                                    <ProgressBar fx:id="participantsProgress" prefWidth="200" progress="0.36"
                                                 style="-fx-accent: #8b5cf6; -fx-pref-height: 8; -fx-background-radius: 6;"/>

                                    <HBox alignment="CENTER_LEFT" spacing="8">
                                        <ImageView fx:id="iconeMessageImage" fitWidth="16" fitHeight="16" preserveRatio="true">
                                            <image><Image url="@assets/votre-image-message.png"/></image>
                                        </ImageView>
                                        <Label text="⚡ DERNIÈRES PLACES ! ⚡"
                                               style="-fx-font-size: 12px; -fx-font-weight: 900; -fx-text-fill: #ef4444;"/>
                                    </HBox>
                                </VBox>

                                <!-- RAPPORT IA (80px) - Blanc avec bordure violette -->
                                <VBox prefWidth="480" maxWidth="480" minHeight="80" maxHeight="80"
                                      style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 12;
                                             -fx-border-color: #8b5cf6; -fx-border-width: 2; -fx-border-radius: 15;
                                             -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.1), 5, 0, 0, 2);"
                                      alignment="CENTER_LEFT">
                                    <Button fx:id="rapportIABtn" text="📊 RAPPORT IA"
                                            maxWidth="440"
                                            style="-fx-background-color: white; -fx-text-fill: #7c3aed;
                                                   -fx-font-size: 14px; -fx-font-weight: bold;
                                                   -fx-background-radius: 25; -fx-padding: 8;
                                                   -fx-border-color: #8b5cf6; -fx-border-width: 2;
                                                   -fx-border-radius: 25; -fx-cursor: hand;"
                                            alignment="CENTER_LEFT"/>
                                </VBox>
                            </VBox>
                        </HBox>

                        <!-- ========== BOUTON PARTICIPER CENTRÉ ========== -->
                        <HBox alignment="CENTER" style="-fx-padding: 15 0 5 0;">
                            <Button fx:id="registerBtn" text="✅ Participer à cet événement"
                                    prefWidth="400"
                                    style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-size: 16px;
                                       -fx-font-weight: bold; -fx-background-radius: 40; -fx-padding: 10 20;
                                       -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.4), 8, 0, 0, 2);"/>
                        </HBox>
                    </VBox>

                    <!-- ========== AVIS ========== -->
                    <VBox spacing="15"
                          style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20;
                                 -fx-border-color: #c4b5fd; -fx-border-width: 2; -fx-border-radius: 20;
                                 -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.2), 12, 0, 0, 4);">

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <ImageView fitWidth="26" fitHeight="26" preserveRatio="true">
                                <image><Image url="@assets/comment.png"/></image>
                            </ImageView>
                            <Label text="Avis des participants"
                                   style="-fx-font-size: 19px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <HBox spacing="8" style="-fx-background-color: #fef9c3; -fx-padding: 5 18; -fx-background-radius: 30;">
                                <Label text="4.8" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #854d0e;"/>
                                <Label text="⭐" style="-fx-font-size: 15px;"/>
                            </HBox>
                        </HBox>

                        <!-- Grille d'avis avec images en cercle -->
                        <GridPane hgap="15" vgap="15">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50" halignment="CENTER"/>
                                <ColumnConstraints percentWidth="50" halignment="CENTER"/>
                            </columnConstraints>

                            <!-- Avis 1 -->
                            <VBox spacing="10"
                                  style="-fx-background-color: #faf5ff; -fx-background-radius: 16; -fx-padding: 16;
                                         -fx-border-color: #d8c9ff; -fx-border-width: 1.5; -fx-border-radius: 16;
                                         -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.1), 6, 0, 0, 2);"
                                  GridPane.rowIndex="0" GridPane.columnIndex="0"
                                  alignment="TOP_LEFT">
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <ImageView fitWidth="45" fitHeight="45" preserveRatio="true"
                                               style="-fx-background-radius: 25; -fx-border-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 3, 0, 0, 1);">
                                        <image><Image url="@assets/user1.jpg"/></image>
                                    </ImageView>
                                    <VBox spacing="2" alignment="CENTER_LEFT">
                                        <Label text="Marie Dubois" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #2d3748;" alignment="CENTER_LEFT"/>
                                        <Label text="Participante" style="-fx-text-fill: #6b7280; -fx-font-size: 12px;" alignment="CENTER_LEFT"/>
                                    </VBox>
                                </HBox>
                                <Label text="⭐⭐⭐⭐⭐" style="-fx-text-fill: #f59e0b; -fx-font-size: 14px;" alignment="CENTER_LEFT"/>
                                <Label text="Ambiance calme et accueillante"
                                       wrapText="true"
                                       style="-fx-text-fill: #4a5568; -fx-font-size: 13px;" alignment="CENTER_LEFT"/>
                            </VBox>

                            <!-- Avis 2 -->
                            <VBox spacing="10"
                                  style="-fx-background-color: #faf5ff; -fx-background-radius: 16; -fx-padding: 16;
                                         -fx-border-color: #d8c9ff; -fx-border-width: 1.5; -fx-border-radius: 16;
                                         -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.1), 6, 0, 0, 2);"
                                  GridPane.rowIndex="0" GridPane.columnIndex="1"
                                  alignment="TOP_LEFT">
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <ImageView fitWidth="45" fitHeight="45" preserveRatio="true"
                                               style="-fx-background-radius: 25; -fx-border-radius: 25;">
                                        <image><Image url="@assets/user2.jpg"/></image>
                                    </ImageView>
                                    <VBox spacing="2" alignment="CENTER_LEFT">
                                        <Label text="Thomas Martin" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #2d3748;" alignment="CENTER_LEFT"/>
                                        <Label text="Parent" style="-fx-text-fill: #6b7280; -fx-font-size: 12px;" alignment="CENTER_LEFT"/>
                                    </VBox>
                                </HBox>
                                <Label text="⭐⭐⭐⭐" style="-fx-text-fill: #f59e0b; -fx-font-size: 14px;" alignment="CENTER_LEFT"/>
                                <Label text="Très belle expérience"
                                       wrapText="true"
                                       style="-fx-text-fill: #4a5568; -fx-font-size: 13px;" alignment="CENTER_LEFT"/>
                            </VBox>

                            <!-- Avis 3 -->
                            <VBox spacing="10"
                                  style="-fx-background-color: #faf5ff; -fx-background-radius: 16; -fx-padding: 16;
                                         -fx-border-color: #d8c9ff; -fx-border-width: 1.5; -fx-border-radius: 16;
                                         -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.1), 6, 0, 0, 2);"
                                  GridPane.rowIndex="1" GridPane.columnIndex="0"
                                  alignment="TOP_LEFT">
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <ImageView fitWidth="45" fitHeight="45" preserveRatio="true"
                                               style="-fx-background-radius: 25; -fx-border-radius: 25;">
                                        <image><Image url="@assets/user3.jpg"/></image>
                                    </ImageView>
                                    <VBox spacing="2" alignment="CENTER_LEFT">
                                        <Label text="Sophie Bernard" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #2d3748;" alignment="CENTER_LEFT"/>
                                        <Label text="Éducatrice" style="-fx-text-fill: #6b7280; -fx-font-size: 12px;" alignment="CENTER_LEFT"/>
                                    </VBox>
                                </HBox>
                                <Label text="⭐⭐⭐⭐⭐" style="-fx-text-fill: #f59e0b; -fx-font-size: 14px;" alignment="CENTER_LEFT"/>
                                <Label text="Équipe attentionnée"
                                       wrapText="true"
                                       style="-fx-text-fill: #4a5568; -fx-font-size: 13px;" alignment="CENTER_LEFT"/>
                            </VBox>

                            <!-- Avis 4 -->
                            <VBox spacing="10"
                                  style="-fx-background-color: #faf5ff; -fx-background-radius: 16; -fx-padding: 16;
                                         -fx-border-color: #d8c9ff; -fx-border-width: 1.5; -fx-border-radius: 16;
                                         -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.1), 6, 0, 0, 2);"
                                  GridPane.rowIndex="1" GridPane.columnIndex="1"
                                  alignment="TOP_LEFT">
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <ImageView fitWidth="45" fitHeight="45" preserveRatio="true"
